.confirm-page {
  min-height: 100vh;
  padding-bottom: 158rpx;
  background: linear-gradient(180deg, #fff0f0 0%, #f4f6fb 360rpx, #f4f6fb 100%);
}

.page-nav {
  height: 92rpx;
  padding: 0 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.78);
  color: #121c34;
  font-size: 58rpx;
  line-height: 58rpx;
  text-align: center;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 900;
}

.nav-action {
  color: #ff1d16;
  font-size: 28rpx;
  font-weight: 800;
}

.route-card {
  padding: 30rpx;
}

.service-badge {
  display: inline-flex;
  height: 52rpx;
  padding: 0 22rpx;
  border-radius: 28rpx;
  background: #fff0ed;
  color: #ff1d16;
  font-size: 24rpx;
  font-weight: 850;
  align-items: center;
  margin-bottom: 20rpx;
}

.route-line {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.route-info {
  flex: 1;
  min-width: 0;
}

.title {
  color: #111c34;
  font-size: 32rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sub {
  margin-top: 8rpx;
  color: #7c879c;
  font-size: 25rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.connector {
  width: 4rpx;
  height: 42rpx;
  margin: 8rpx 0 8rpx 22rpx;
  background: linear-gradient(180deg, #ff1712, #10c779);
  border-radius: 4rpx;
}

.option-card,
.price-card {
  padding: 30rpx;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.section-head .muted {
  font-size: 23rpx;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.chip,
.weight {
  min-width: 142rpx;
  height: 62rpx;
  padding: 0 22rpx;
  border-radius: 18rpx;
  background: #f5f7fb;
  color: #566176;
  font-size: 26rpx;
  font-weight: 750;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chip.active,
.weight.active {
  color: #ff1d16;
  background: #fff0ed;
  box-shadow: inset 0 0 0 3rpx rgba(255, 29, 22, 0.18);
}

.weight-row {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  color: #111c34;
  font-size: 28rpx;
  font-weight: 850;
}

.weight-list {
  display: flex;
  gap: 12rpx;
}

.weight {
  min-width: 82rpx;
  height: 54rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
}

textarea {
  width: 100%;
  min-height: 92rpx;
  margin-top: 28rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #f6f8fc;
  color: #111c34;
  font-size: 26rpx;
}

.arrival {
  color: #10b775;
  font-size: 24rpx;
  font-weight: 850;
}

.price-row {
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #69748a;
  font-size: 27rpx;
}

.price-row text:last-child {
  color: #111c34;
  font-weight: 850;
}

.price-row.discount text:last-child {
  color: #ff1d16;
}

.guarantee {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: #f3fffa;
  display: flex;
  gap: 18rpx;
  align-items: center;
}

.check {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  border: 3rpx solid #c8d0df;
  color: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check.checked {
  border-color: #10c779;
  color: #fff;
  background: #10c779;
}

.guarantee-title {
  color: #111c34;
  font-size: 27rpx;
  font-weight: 850;
}

.guarantee-sub {
  margin-top: 6rpx;
  color: #6c778d;
  font-size: 23rpx;
}

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  min-height: 128rpx;
  padding: 18rpx 30rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 -12rpx 36rpx rgba(20, 28, 50, 0.07);
}

.amount {
  width: 190rpx;
}

.amount .muted {
  font-size: 23rpx;
}

.money {
  color: #ff1d16;
  font-size: 42rpx;
  font-weight: 950;
}

.pay-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 50rpx;
  color: #fff;
  font-size: 31rpx;
  font-weight: 900;
  background: linear-gradient(90deg, #ff7b00, #ff160c 72%, #f80505);
  display: flex;
  align-items: center;
  justify-content: center;
}
