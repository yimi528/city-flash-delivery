<view class="profile-page">
  <view style="height: {{statusBarHeight}}px"></view>

  <view class="nav-shell">
    <view class="nav-title">个人中心</view>
    <view class="menu-pill"><text>•••</text><view class="pill-dot"></view></view>
  </view>

  <view class="member-card" bindtap="openMember">
    <view class="member-main">
      <view class="member-phone">{{displayPhone}}</view>
      <view class="member-level">{{memberLevel}}</view>
      <view class="member-desc">升级后享受多项权益</view>
    </view>
    <view class="member-more">查看更多›</view>
    <view class="diamond">
      <view class="diamond-top"></view>
      <view class="diamond-core"></view>
      <view class="diamond-side"></view>
    </view>
  </view>

  <view class="balance-card">
    <block wx:for="{{stats}}" wx:key="label">
      <view class="balance-item" bindtap="openCoupons">
        <view class="badge" wx:if="{{item.badge}}">{{item.badge}}</view>
        <view class="balance-value">{{item.value}}</view>
        <view class="balance-label">{{item.label}}</view>
      </view>
    </block>
  </view>

  <view class="panel order-panel">
    <view class="panel-head">
      <view class="panel-title">我的订单</view>
      <view class="panel-link" bindtap="openOrders">全部订单›</view>
    </view>
    <view class="status-grid">
      <block wx:for="{{orderStatus}}" wx:key="name">
        <view class="status-item" data-filter="{{item.filter}}" bindtap="openOrderStatus">
          <view class="order-icon {{item.iconClass}}"></view>
          <view>{{item.name}}</view>
        </view>
      </block>
    </view>
  </view>

  <view class="panel service-panel">
    <view class="panel-title">我的服务</view>
    <view class="service-grid">
      <block wx:for="{{services}}" wx:key="name">
        <view class="service-item" data-name="{{item.name}}" data-action="{{item.action}}" bindtap="openTool">
          <view class="service-icon {{item.iconClass}}"></view>
          <view class="service-name">{{item.name}}</view>
        </view>
      </block>
    </view>
  </view>

  <view class="promo-strip">
    <view>
      <view class="promo-title">送加享专属福利官</view>
      <view class="promo-sub">邀请好友注册得优惠券</view>
    </view>
    <view class="rider-face">速</view>
  </view>
</view>
