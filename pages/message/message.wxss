.message-page {
  min-height: 100vh;
  padding-bottom: 140rpx;
  background: linear-gradient(180deg, #fff0f0 0%, #f4f6fb 330rpx, #f4f6fb 100%);
}

.topbar {
  padding: 34rpx 30rpx 18rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.title {
  color: #111c34;
  font-size: 44rpx;
  font-weight: 950;
}

.subtitle {
  margin-top: 8rpx;
  color: #7b8497;
  font-size: 25rpx;
}

.bell {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  background: #fff;
  color: #ff1d16;
  font-size: 28rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 30rpx rgba(20, 28, 50, 0.06);
}

.notice-card {
  margin: 18rpx 30rpx 0;
  padding: 34rpx;
  border-radius: 30rpx;
  background: linear-gradient(130deg, #111d37, #284b8d 68%, #ff3b2f 100%);
  color: #fff;
  box-shadow: 0 18rpx 42rpx rgba(20, 32, 64, 0.14);
}

.notice-title {
  font-size: 36rpx;
  font-weight: 950;
}

.notice-sub {
  margin-top: 12rpx;
  color: #dce6ff;
  font-size: 26rpx;
  line-height: 1.55;
}

.message-list {
  margin-top: 12rpx;
}

.message-item {
  position: relative;
  margin: 20rpx 30rpx 0;
  padding: 28rpx;
  border-radius: 28rpx;
  background: #fff;
  display: flex;
  align-items: center;
  gap: 22rpx;
  box-shadow: 0 14rpx 34rpx rgba(20, 28, 50, 0.05);
}

.icon {
  width: 70rpx;
  height: 70rpx;
  border-radius: 22rpx;
  background: #fff0ed;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  flex-shrink: 0;
}

.msg-main {
  flex: 1;
  min-width: 0;
}

.msg-head {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
}

.msg-title {
  color: #111c34;
  font-size: 30rpx;
  font-weight: 900;
}

.time {
  color: #a0a8b9;
  font-size: 23rpx;
}

.msg-body {
  margin-top: 10rpx;
  color: #758096;
  font-size: 25rpx;
  line-height: 1.45;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.unread {
  position: absolute;
  right: 24rpx;
  top: 24rpx;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #ff1712;
}
