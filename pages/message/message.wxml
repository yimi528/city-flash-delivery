<view class="message-page">
  <view style="height: {{statusBarHeight}}px"></view>

  <view class="nav-shell">
    <view class="back" bindtap="goBack">‹</view>
    <view class="nav-title">我的消息</view>
    <view class="menu-pill" bindtap="openMenu"><text>•••</text><view class="pill-dot"></view></view>
  </view>

  <view class="message-list" wx:if="{{messages.length}}">
    <block wx:for="{{messages}}" wx:key="title">
      <view class="message-item" data-index="{{index}}" bindtap="openMessage">
        <view class="message-icon {{item.unread ? 'hot' : ''}}">{{item.icon}}</view>
        <view class="message-main">
          <view class="message-head">
            <view class="message-title">{{item.title}}</view>
            <view class="message-time">{{item.time}}</view>
          </view>
          <view class="message-body">{{item.body}}</view>
        </view>
        <view class="unread" wx:if="{{item.unread}}"></view>
      </view>
    </block>
  </view>

  <view class="empty-panel" wx:else>
    <view class="sign-art">
      <view class="post"></view>
      <view class="board board-a"></view>
      <view class="board board-b"></view>
      <view class="board board-c"></view>
      <view class="green-stroke stroke-a"></view>
      <view class="green-stroke stroke-b"></view>
      <view class="shadow"></view>
    </view>
    <view class="empty-copy">暂无消息</view>
  </view>
</view>
