<view class="orders-page">
  <view style="height: {{statusBarHeight}}px"></view>
  <view class="topbar">
    <view>
      <view class="title">我的订单</view>
      <view class="subtitle">实时查看同城配送进度</view>
    </view>
    <view class="top-pill" bindtap="goHome">再下一单</view>
  </view>

  <view class="filter-bar">
    <block wx:for="{{filters}}" wx:key="*this">
      <view class="filter {{filter === item ? 'active' : ''}}" data-filter="{{item}}" bindtap="changeFilter">{{item}}</view>
    </block>
  </view>

  <view class="order-list" wx:if="{{orders.length}}">
    <block wx:for="{{orders}}" wx:key="id">
      <view class="order-card" data-id="{{item.id}}" bindtap="openOrder">
        <view class="order-head">
          <view class="service">{{item.service}}</view>
          <view class="status {{item.status === '已完成' ? 'done' : ''}}">{{item.status}}</view>
        </view>
        <view class="route">
          <view class="dot red"></view>
          <view class="route-name">{{item.pickupName}}</view>
        </view>
        <view class="route">
          <view class="dot green"></view>
          <view class="route-name">{{item.dropoffName}}</view>
        </view>
        <view class="order-foot">
          <text>{{item.item}} · {{item.distance}}km · {{item.createTime}}</text>
          <text class="fee">￥{{item.fee}}</text>
        </view>
      </view>
    </block>
  </view>

  <view class="empty" wx:else>
    <view class="empty-icon">📦</view>
    <view class="empty-title">暂无订单</view>
    <view class="empty-sub">选择地址后，第一单会出现在这里。</view>
    <button class="primary-btn" bindtap="goHome">去下单</button>
  </view>
</view>
