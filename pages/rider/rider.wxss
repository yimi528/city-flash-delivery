.rider-page {
  min-height: 100vh;
  padding-bottom: 140rpx;
  background: linear-gradient(180deg, #eaf6ff 0%, #f4f6fb 390rpx, #f4f6fb 100%);
}

.page-nav {
  height: 104rpx;
  padding: 12rpx 30rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.78);
  color: #121c34;
  font-size: 58rpx;
  line-height: 58rpx;
  text-align: center;
}

.nav-title {
  color: #111c34;
  font-size: 38rpx;
  font-weight: 950;
}

.nav-action {
  height: 56rpx;
  padding: 0 24rpx;
  border-radius: 28rpx;
  color: #fff;
  background: #0f1f3d;
  font-size: 24rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
}

.rider-card {
  min-height: 192rpx;
  margin: 22rpx 30rpx 0;
  padding: 34rpx;
  border-radius: 30rpx;
  background:
    radial-gradient(circle at 88% 18%, rgba(255, 255, 255, 0.22), transparent 24%),
    linear-gradient(135deg, #081a34, #0d6f8f 63%, #21d17c 100%);
  color: #fff;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  box-shadow: 0 18rpx 42rpx rgba(20, 32, 64, 0.14);
}

.rider-kicker {
  color: #c8fff0;
  font-size: 24rpx;
  font-weight: 800;
}

.rider-name {
  margin-top: 10rpx;
  font-size: 42rpx;
  font-weight: 950;
}

.rider-meta {
  margin-top: 14rpx;
  color: #dcefff;
  font-size: 24rpx;
}

.rider-status {
  height: 50rpx;
  padding: 0 18rpx;
  border-radius: 26rpx;
  font-size: 23rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
}

.rider-status.on { background: #10c779; }
.rider-status.off { background: #9099ad; }

.stats-card {
  min-height: 150rpx;
  margin: 22rpx 30rpx 0;
  border-radius: 28rpx;
  background: #fff;
  display: flex;
  box-shadow: 0 14rpx 34rpx rgba(20, 28, 50, 0.05);
}

.stat-item {
  flex: 1;
  padding-top: 30rpx;
  text-align: center;
}

.stat-value {
  color: #111c34;
  font-size: 33rpx;
  font-weight: 950;
  white-space: nowrap;
}

.stat-label {
  margin-top: 12rpx;
  color: #7d879b;
  font-size: 23rpx;
}

.filter-scroll {
  width: 100%;
  white-space: nowrap;
  margin-top: 28rpx;
}

.filter-row {
  display: inline-flex;
  gap: 20rpx;
  padding: 0 30rpx;
}

.filter {
  height: 60rpx;
  padding: 0 26rpx;
  border-radius: 32rpx;
  color: #68738a;
  background: #fff;
  font-size: 25rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
}

.filter.active {
  color: #fff;
  background: #0f8f74;
  box-shadow: 0 12rpx 22rpx rgba(15, 143, 116, 0.18);
}

.order-section {
  margin-top: 4rpx;
}

.rider-order {
  margin: 22rpx 30rpx 0;
  padding: 30rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 14rpx 34rpx rgba(20, 28, 50, 0.05);
}

.order-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.order-id {
  color: #111c34;
  font-size: 30rpx;
  font-weight: 950;
}

.order-time {
  margin-top: 8rpx;
  color: #8a94a8;
  font-size: 23rpx;
}

.phase-pill {
  height: 46rpx;
  padding: 0 18rpx;
  border-radius: 24rpx;
  color: #0f1f3d;
  background: #eef2f8;
  font-size: 23rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
}

.phase-pill.hot {
  color: #0f8f74;
  background: #e9fff8;
}

.goods-box {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f0fbff;
}

.goods-title {
  color: #111c34;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.45;
}

.goods-meta {
  margin-top: 10rpx;
  color: #7d879b;
  font-size: 24rpx;
}

.route-line {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.pin {
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
  color: #fff;
  font-size: 24rpx;
  font-weight: 950;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.pin.pickup { background: #ff7b00; }
.pin.dropoff { background: #10c779; }

.route-main {
  flex: 1;
  min-width: 0;
  color: #111c34;
  font-size: 28rpx;
  font-weight: 900;
}

.route-main text {
  display: block;
  margin-top: 7rpx;
  color: #8a94a8;
  font-size: 23rpx;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rider-primary-action,
.rider-done {
  margin-top: 26rpx;
  height: 84rpx;
  border-radius: 44rpx;
  font-size: 29rpx;
  font-weight: 950;
  display: flex;
  align-items: center;
  justify-content: center;
}

.rider-primary-action {
  gap: 10rpx;
  color: #fff;
  background: linear-gradient(90deg, #00aa8a, #10c779);
  box-shadow: 0 14rpx 28rpx rgba(16, 199, 121, 0.18);
}

.action-arrow {
  font-size: 38rpx;
  line-height: 1;
}

.rider-done {
  color: #10a66d;
  background: #ecfff6;
}

.empty {
  height: 360rpx;
  margin: 22rpx 30rpx 0;
  border-radius: 28rpx;
  background: #fff;
  color: #98a1b3;
  font-size: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-icon {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 20rpx;
  border-radius: 32rpx;
  background: #eafff7;
  color: #0f8f74;
  font-size: 38rpx;
  font-weight: 950;
  display: flex;
  align-items: center;
  justify-content: center;
}
