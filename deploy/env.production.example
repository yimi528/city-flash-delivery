# Compose images and public domains
API_IMAGE=ccr.ccs.tencentyun.com/your-namespace/city-flash-api:replace-with-git-sha
API_MIGRATION_IMAGE=ccr.ccs.tencentyun.com/your-namespace/city-flash-api-migration:replace-with-git-sha
MERCHANT_IMAGE=ccr.ccs.tencentyun.com/your-namespace/city-flash-merchant:replace-with-git-sha
API_DOMAIN=api.example.com
OPS_DOMAIN=ops.example.com

# API runtime
NODE_ENV=production
PORT=3000
API_PREFIX=api
CORS_ORIGINS=https://ops.example.com
ENABLE_SWAGGER=false
DATABASE_URL=postgresql://city_flash:replace-me@10.0.0.10:5432/city_flash?schema=public&sslmode=require
REDIS_URL=redis://:replace-me@10.0.0.20:6379
JWT_SECRET=replace-with-at-least-32-random-bytes
AUTH_TOKEN_TTL_SECONDS=604800
CUSTOMER_AUTH_TOKEN_TTL_SECONDS=604800
RIDER_AUTH_TOKEN_TTL_SECONDS=86400
OPERATOR_AUTH_TOKEN_TTL_SECONDS=28800

# WeChat Mini Program login
WECHAT_MINI_APP_ID=replace-me
WECHAT_MINI_APP_SECRET=replace-me
WECHAT_LOGIN_MOCK_ENABLED=false

RIDER_ORDER_RADIUS_KM=30
RIDER_HEARTBEAT_TIMEOUT_SECONDS=90

# Initial operator. Run operator-init once, then remove the password from this file.
OPERATOR_BOOTSTRAP_ENABLED=false
OPERATOR_BOOTSTRAP_USERNAME=city-flash-admin
OPERATOR_BOOTSTRAP_PASSWORD=replace-with-a-strong-password
OPERATOR_BOOTSTRAP_NAME=同城速送管理员

# WeChat Pay API v3
WECHAT_PAY_MOCK_ENABLED=false
WECHAT_PAY_MCH_ID=replace-me
WECHAT_PAY_CERT_SERIAL=replace-me
WECHAT_PAY_PRIVATE_KEY_PATH=/run/secrets/apiclient_key.pem
WECHAT_PAY_PRIVATE_KEY=
WECHAT_PAY_API_V3_KEY=replace-with-32-byte-api-v3-key
WECHAT_PAY_PLATFORM_CERT_SERIAL=replace-me
WECHAT_PAY_PLATFORM_CERT_PATH=/run/secrets/wechatpay_platform.pem
WECHAT_PAY_PLATFORM_CERT=
WECHAT_PAY_NOTIFY_URL=https://api.example.com/api/payments/wechat/notify
WECHAT_PAY_REFUND_NOTIFY_URL=https://api.example.com/api/payments/wechat/refund-notify
WECHAT_PAY_AUTO_RECONCILIATION_ENABLED=true

# Tencent Map and pricing
TENCENT_MAP_KEY=replace-with-a-rotated-production-key
BAD_WEATHER_MULTIPLIER=1.15
