.merchant-page {
  min-height: 100vh;
  padding-bottom: 140rpx;
  background: linear-gradient(180deg, #fff1e7 0%, #f4f6fb 380rpx, #f4f6fb 100%);
}

.page-nav {
  height: 104rpx;
  padding: 12rpx 30rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.78);
  color: #121c34;
  font-size: 58rpx;
  line-height: 58rpx;
  text-align: center;
}

.nav-title {
  color: #111c34;
  font-size: 38rpx;
  font-weight: 950;
}

.nav-action {
  height: 56rpx;
  padding: 0 24rpx;
  border-radius: 28rpx;
  color: #fff;
  background: #0f1f3d;
  font-size: 24rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
}

.store-card {
  min-height: 192rpx;
  margin: 22rpx 30rpx 0;
  padding: 34rpx;
  border-radius: 30rpx;
  background: linear-gradient(135deg, #111d37, #284b8d 64%, #ff5b22 100%);
  color: #fff;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  box-shadow: 0 18rpx 42rpx rgba(20, 32, 64, 0.14);
}

.store-kicker {
  color: #ffd7c2;
  font-size: 24rpx;
  font-weight: 800;
}

.store-name {
  margin-top: 10rpx;
  font-size: 39rpx;
  font-weight: 950;
}

.store-address {
  margin-top: 14rpx;
  color: #dce6ff;
  font-size: 24rpx;
}

.store-status {
  height: 50rpx;
  padding: 0 18rpx;
  border-radius: 26rpx;
  font-size: 23rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
}

.store-status.on { background: #10c779; }
.store-status.off { background: #9099ad; }

.stats-card {
  min-height: 150rpx;
  margin: 22rpx 30rpx 0;
  border-radius: 28rpx;
  background: #fff;
  display: flex;
  box-shadow: 0 14rpx 34rpx rgba(20, 28, 50, 0.05);
}

.stat-item {
  flex: 1;
  padding-top: 30rpx;
  text-align: center;
}

.stat-value {
  color: #111c34;
  font-size: 33rpx;
  font-weight: 950;
  white-space: nowrap;
}

.stat-label {
  margin-top: 12rpx;
  color: #7d879b;
  font-size: 23rpx;
}

.filter-scroll {
  width: 100%;
  white-space: nowrap;
  margin-top: 28rpx;
}

.filter-row {
  display: inline-flex;
  gap: 20rpx;
  padding: 0 30rpx;
}

.filter {
  height: 60rpx;
  padding: 0 26rpx;
  border-radius: 32rpx;
  color: #68738a;
  background: #fff;
  font-size: 25rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
}

.filter.active {
  color: #fff;
  background: #ff1712;
  box-shadow: 0 12rpx 22rpx rgba(255, 23, 18, 0.18);
}

.order-section {
  margin-top: 4rpx;
}

.merchant-order,
.product-card {
  margin: 22rpx 30rpx 0;
  padding: 30rpx;
  border-radius: 28rpx;
  background: #fff;
  box-shadow: 0 14rpx 34rpx rgba(20, 28, 50, 0.05);
}

.order-head,
.order-actions,
.section-head,
.product-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.order-id {
  color: #111c34;
  font-size: 30rpx;
  font-weight: 950;
}

.order-time {
  margin-top: 8rpx;
  color: #8a94a8;
  font-size: 23rpx;
}

.merchant-status {
  height: 46rpx;
  padding: 0 18rpx;
  border-radius: 24rpx;
  color: #0f1f3d;
  background: #eef2f8;
  font-size: 23rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
}

.merchant-status.hot {
  color: #ff1712;
  background: #fff0ed;
}

.goods-box {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: #fff7f3;
}

.goods-title {
  color: #111c34;
  font-size: 30rpx;
  font-weight: 900;
  line-height: 1.45;
}

.goods-meta,
.goods-note {
  margin-top: 10rpx;
  color: #7d879b;
  font-size: 24rpx;
}

.goods-note {
  color: #ff5a22;
}

.merchant-primary-action {
  margin-top: 22rpx;
  height: 82rpx;
  border-radius: 42rpx;
  color: #fff;
  background: linear-gradient(90deg, #ff8a00, #ff1712);
  font-size: 29rpx;
  font-weight: 950;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  box-shadow: 0 14rpx 28rpx rgba(255, 53, 20, 0.18);
}

.action-arrow {
  font-size: 38rpx;
  line-height: 1;
}

.route-line {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.pin {
  width: 48rpx;
  height: 48rpx;
  border-radius: 14rpx;
  color: #fff;
  font-size: 24rpx;
  font-weight: 950;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.pin.buy { background: #ff7b00; }
.pin.send { background: #10c779; }

.route-main {
  flex: 1;
  min-width: 0;
  color: #111c34;
  font-size: 28rpx;
  font-weight: 900;
}

.route-main text {
  display: block;
  margin-top: 7rpx;
  color: #8a94a8;
  font-size: 23rpx;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.order-actions {
  margin-top: 26rpx;
  display: flex;
  gap: 18rpx;
}

.ghost,
.solid {
  height: 68rpx;
  border-radius: 36rpx;
  font-size: 25rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ghost {
  flex: 1;
  color: #5f6b82;
  background: #f2f5fa;
}

.solid {
  flex: 1;
  color: #fff;
  background: linear-gradient(90deg, #ff7b00, #ff160c 72%, #f80505);
}

.empty {
  height: 360rpx;
  margin: 22rpx 30rpx 0;
  border-radius: 28rpx;
  background: #fff;
  color: #98a1b3;
  font-size: 28rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.empty-icon {
  width: 96rpx;
  height: 96rpx;
  margin-bottom: 20rpx;
  border-radius: 32rpx;
  background: #fff0ed;
  color: #ff1712;
  font-size: 38rpx;
  font-weight: 950;
  display: flex;
  align-items: center;
  justify-content: center;
}

.product-card {
  padding-bottom: 12rpx;
}

.section-title {
  color: #111c34;
  font-size: 34rpx;
  font-weight: 950;
}

.section-sub,
.avg-time {
  margin-top: 8rpx;
  color: #8a94a8;
  font-size: 24rpx;
}

.avg-time {
  margin-top: 0;
  color: #ff1712;
  font-weight: 800;
}

.product-row {
  min-height: 104rpx;
  border-top: 2rpx solid #f1f3f8;
}

.product-row:first-of-type {
  margin-top: 18rpx;
}

.product-name {
  color: #111c34;
  font-size: 28rpx;
  font-weight: 900;
}

.product-sub {
  margin-top: 8rpx;
  color: #8a94a8;
  font-size: 23rpx;
}

.soldout {
  width: 104rpx;
  height: 50rpx;
  border-radius: 26rpx;
  color: #10a66d;
  background: #eafff7;
  font-size: 23rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.soldout.off {
  color: #98a1b3;
  background: #f0f2f6;
}
