page {
  color: #151922;
  background: #f4f6f8;
  font-family: "PingFang SC", "Hiragino Sans GB", sans-serif;
  --rider-ink: #151922;
  --rider-muted: #7a8494;
  --rider-paper: #ffffff;
  --rider-line: #e8edf3;
  --rider-blue: #1677ff;
  --rider-blue-soft: #edf5ff;
  --rider-green: #18a66a;
  --rider-red: #d4493f;
  --line: var(--rider-line);
  --cinnabar: var(--rider-red);
  --jade: var(--rider-green);
  --ease-out: cubic-bezier(.2, .8, .2, 1);
}

.rider-page {
  min-height: 100vh;
  padding: 24rpx 28rpx 190rpx;
  box-sizing: border-box;
}

.rider-card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border: 2rpx solid var(--rider-line);
  border-radius: 28rpx;
  background: var(--rider-paper);
  box-shadow: 0 12rpx 30rpx rgba(31, 45, 61, .05);
}

.rider-muted { color: var(--rider-muted); font-size: 23rpx; }
.rider-primary { color: #fff; background: var(--rider-blue); font-weight: 850; }

.rider-empty {
  padding: 100rpx 30rpx;
  color: #8a93a1;
  text-align: center;
  line-height: 1.7;
}

.rider-nav {
  position: fixed;
  z-index: 30;
  left: 24rpx;
  right: 24rpx;
  bottom: calc(18rpx + env(safe-area-inset-bottom));
  height: 108rpx;
  padding: 8rpx;
  border: 2rpx solid rgba(219, 226, 235, .9);
  border-radius: 32rpx;
  background: rgba(255, 255, 255, .96);
  box-shadow: 0 18rpx 50rpx rgba(31, 45, 61, .14);
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.rider-nav-item {
  flex: 1;
  height: 88rpx;
  border-radius: 24rpx;
  color: #8993a2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 7rpx;
  font-size: 20rpx;
  font-weight: 750;
  line-height: 1;
  transition: transform 120ms var(--ease-out), color 120ms ease, background-color 120ms ease;
}

.rider-nav-item.active { color: var(--rider-blue); background: var(--rider-blue-soft); }
.rider-nav-item:active { transform: scale(.96); }
.rider-nav-label { white-space: nowrap; }
.rider-nav-glyph { position: relative; width: 34rpx; height: 34rpx; color: currentColor; }
.rider-nav-glyph::before, .rider-nav-glyph::after { box-sizing: border-box; }
.rider-nav-glyph.hall { border: 3rpx solid currentColor; border-radius: 50%; }
.rider-nav-glyph.hall::before { content: ''; position: absolute; left: 50%; top: 50%; width: 8rpx; height: 8rpx; border-radius: 50%; background: currentColor; transform: translate(-50%, -50%); }
.rider-nav-glyph.hall::after { content: ''; position: absolute; left: 5rpx; top: 5rpx; width: 18rpx; height: 18rpx; border-top: 3rpx solid currentColor; border-right: 3rpx solid currentColor; border-radius: 0 14rpx 0 0; }
.rider-nav-glyph.tasks { width: 28rpx; height: 34rpx; border: 3rpx solid currentColor; border-radius: 7rpx; }
.rider-nav-glyph.tasks::before { content: ''; position: absolute; left: 6rpx; top: 8rpx; width: 12rpx; height: 3rpx; border-radius: 999rpx; background: currentColor; box-shadow: 0 8rpx 0 currentColor, 0 16rpx 0 currentColor; }
.rider-nav-glyph.profile::before { content: ''; position: absolute; left: 10rpx; top: 1rpx; width: 14rpx; height: 14rpx; border: 3rpx solid currentColor; border-radius: 50%; }
.rider-nav-glyph.profile::after { content: ''; position: absolute; left: 3rpx; bottom: 0; width: 28rpx; height: 14rpx; border: 3rpx solid currentColor; border-bottom: 0; border-radius: 18rpx 18rpx 0 0; }

button::after { border: 0; }

@media (prefers-reduced-motion: reduce) {
  .rider-nav-item { transition: color 120ms ease, background-color 120ms ease; }
  .rider-nav-item:active { transform: none; }
}
