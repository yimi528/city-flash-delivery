page {
  min-height: 100%;
  color: #18201d;
  background: #f4f0e8;
  font-family: "PingFang SC", "Hiragino Sans GB", sans-serif;
  --ink: #18201d;
  --muted: #787b73;
  --paper: #fffdf8;
  --canvas: #f4f0e8;
  --line: rgba(24, 32, 29, 0.1);
  --cinnabar: #d4472d;
  --cinnabar-strong: #b92f20;
  --jade: #28745c;
  --ease-out: cubic-bezier(0.23, 1, 0.32, 1);
}

view,
text,
button,
input,
textarea {
  box-sizing: border-box;
}

button {
  padding: 0;
  margin: 0;
  border: 0;
  border-radius: 0;
  background: transparent;
  line-height: 1.2;
  transition: transform 140ms var(--ease-out), opacity 140ms var(--ease-out);
}

button::after {
  border: 0;
}

button:active,
.task-card:active,
.price-strip:active,
.route-row:active,
.locate:active {
  transform: scale(0.97);
}

.safe-page {
  min-height: 100vh;
  padding-bottom: 32rpx;
  background:
    radial-gradient(circle at 88% 2%, rgba(212, 71, 45, 0.16), transparent 260rpx),
    linear-gradient(180deg, #f9f2e8 0%, var(--canvas) 42%, var(--canvas) 100%);
}

.nav-pad {
  height: 24px;
}

.card {
  margin: 24rpx 30rpx 0;
  border-radius: 30rpx;
  border: 2rpx solid var(--line);
  background: var(--paper);
  box-shadow: 0 18rpx 48rpx rgba(48, 39, 27, 0.06);
}

.primary-btn {
  height: 96rpx;
  border-radius: 60rpx;
  color: #fff;
  font-size: 34rpx;
  font-weight: 800;
  background: linear-gradient(110deg, var(--cinnabar), var(--cinnabar-strong));
  box-shadow: 0 16rpx 30rpx rgba(185, 47, 32, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ghost-btn {
  min-width: 132rpx;
  height: 56rpx;
  border: 2rpx solid #dce2ef;
  border-radius: 12rpx;
  color: #68738a;
  font-size: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.section-title {
  font-size: 36rpx;
  font-weight: 900;
  letter-spacing: -1rpx;
}

.muted {
  color: var(--muted);
}

.price-red {
  color: #ff1712;
  font-weight: 900;
}

.tag-red,
.tag-green,
.tag-blue {
  width: 46rpx;
  height: 46rpx;
  border-radius: 14rpx;
  color: #fff;
  font-size: 26rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tag-red { background: var(--cinnabar); }
.tag-green { background: var(--jade); }
.tag-blue { background: #2378ff; }

@media (prefers-reduced-motion: reduce) {
  button,
  .task-card,
  .price-strip,
  .route-row,
  .locate {
    transition: opacity 120ms ease;
  }

  button:active,
  .task-card:active,
  .price-strip:active,
  .route-row:active,
  .locate:active {
    transform: none;
  }
}
