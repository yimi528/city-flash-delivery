.detail-page {
  min-height: 100vh;
  padding-bottom: 150rpx;
  background: linear-gradient(180deg, #fff0f0 0%, #f4f6fb 360rpx, #f4f6fb 100%);
}

.page-nav {
  height: 92rpx;
  padding: 0 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.78);
  color: #121c34;
  font-size: 58rpx;
  line-height: 58rpx;
  text-align: center;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 900;
}

.nav-action {
  color: #ff1d16;
  font-size: 28rpx;
  font-weight: 800;
}

.sync-action {
  min-width: 72rpx;
  text-align: right;
}

.status-hero {
  margin: 20rpx 30rpx 0;
  padding: 34rpx;
  border-radius: 30rpx;
  background: linear-gradient(130deg, #121d36, #213d79 62%, #ff3b2f 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 18rpx 42rpx rgba(20, 32, 64, 0.16);
}

.status-name {
  font-size: 44rpx;
  font-weight: 950;
}

.status-sub {
  margin-top: 10rpx;
  color: #dce6ff;
  font-size: 26rpx;
}

.status-sync {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 23rpx;
  font-weight: 700;
}

.sync-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #15d982;
  box-shadow: 0 0 0 8rpx rgba(21, 217, 130, 0.14);
}

.status-sync.syncing .sync-dot {
  background: #ffd36a;
  box-shadow: 0 0 0 8rpx rgba(255, 211, 106, 0.18);
}

.status-price {
  font-size: 38rpx;
  font-weight: 950;
}

.mini-map {
  height: 260rpx;
  position: relative;
  overflow: hidden;
  background: #eaf0f7;
}

.route-road {
  position: absolute;
  height: 42rpx;
  border-radius: 24rpx;
  background: #fff;
  border: 4rpx solid #dce5f2;
}

.road-one {
  width: 660rpx;
  left: -64rpx;
  top: 102rpx;
  transform: rotate(-14deg);
}

.road-two {
  width: 540rpx;
  left: 170rpx;
  top: 134rpx;
  transform: rotate(24deg);
}

.point,
.bike {
  position: absolute;
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 900;
  box-shadow: 0 10rpx 22rpx rgba(20, 28, 50, 0.16);
}

.start { left: 76rpx; top: 128rpx; background: #ff1712; }
.end { right: 82rpx; top: 90rpx; background: #10c779; }
.bike { left: 330rpx; top: 104rpx; background: #13213d; border-radius: 50%; }

.map-mask {
  position: absolute;
  left: 26rpx;
  right: 26rpx;
  bottom: 22rpx;
  height: 58rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #13213d;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 800;
}

.timeline-card,
.info-card,
.merchant-card {
  padding: 30rpx;
}

.timeline {
  margin-top: 26rpx;
  display: flex;
  justify-content: space-between;
}

.step {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #98a1b3;
  position: relative;
}

.step:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 62%;
  top: 23rpx;
  width: 76%;
  height: 4rpx;
  background: #e3e8f2;
}

.step.active:not(:last-child)::after {
  background: #ff655f;
}

.dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #e8edf6;
  color: #8a94a8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
  z-index: 2;
}

.step.active .dot {
  color: #fff;
  background: #ff1712;
}

.step-text {
  margin-top: 14rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.step.active .step-text {
  color: #111c34;
}

.cancel-tip {
  margin-top: 24rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #fff2f1;
  color: #ff1d16;
  font-size: 25rpx;
}

.merchant-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.section-sub {
  margin-top: 8rpx;
  color: #8b95a8;
  font-size: 24rpx;
}

.merchant-pill {
  flex-shrink: 0;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  color: #ff1d16;
  background: #fff1ef;
  font-size: 24rpx;
  font-weight: 900;
}

.merchant-flow {
  margin-top: 28rpx;
  display: flex;
  justify-content: space-between;
}

.merchant-step {
  width: 25%;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #98a1b3;
}

.merchant-step:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 62%;
  top: 21rpx;
  width: 76%;
  height: 4rpx;
  background: #e3e8f2;
}

.merchant-step.active:not(:last-child)::after {
  background: #ff8848;
}

.merchant-dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #e8edf6;
  color: #8a94a8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 21rpx;
  font-weight: 900;
  z-index: 2;
}

.merchant-step.active .merchant-dot {
  color: #fff;
  background: linear-gradient(135deg, #ff8a00, #ff170f);
}

.merchant-label {
  margin-top: 12rpx;
  font-size: 23rpx;
  font-weight: 800;
}

.merchant-step.active .merchant-label {
  color: #111c34;
}

.merchant-primary,
.merchant-done {
  margin-top: 28rpx;
  height: 82rpx;
  border-radius: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
}

.merchant-primary {
  color: #fff;
  background: linear-gradient(90deg, #ff8a00, #ff170f);
  box-shadow: 0 14rpx 28rpx rgba(255, 53, 20, 0.18);
}

.merchant-done {
  color: #10a66d;
  background: #ecfff6;
}

.info-row {
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
  color: #68738a;
}

.info-row text:last-child {
  color: #111c34;
  font-weight: 800;
  max-width: 440rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 18rpx 30rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  display: flex;
  align-items: center;
  gap: 18rpx;
  box-shadow: 0 -12rpx 36rpx rgba(20, 28, 50, 0.07);
}

.outline,
.solid {
  height: 84rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.outline {
  width: 178rpx;
  color: #5f6b82;
  background: #f2f5fa;
}

.solid {
  flex: 1;
  color: #fff;
  background: linear-gradient(90deg, #ff7b00, #ff160c 72%, #f80505);
}
