.detail-page {
  min-height: 100vh;
  padding-bottom: 150rpx;
  background: linear-gradient(180deg, #fff0f0 0%, #f4f6fb 360rpx, #f4f6fb 100%);
}

.page-nav {
  height: 92rpx;
  padding: 0 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.78);
  color: #121c34;
  font-size: 58rpx;
  line-height: 58rpx;
  text-align: center;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 900;
}

.nav-action {
  color: #ff1d16;
  font-size: 28rpx;
  font-weight: 800;
}

.sync-action {
  min-width: 72rpx;
  text-align: right;
}

.status-hero {
  margin: 20rpx 30rpx 0;
  padding: 34rpx;
  border-radius: 30rpx;
  background: linear-gradient(130deg, #121d36, #213d79 62%, #ff3b2f 100%);
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-shadow: 0 18rpx 42rpx rgba(20, 32, 64, 0.16);
}

.status-name {
  font-size: 44rpx;
  font-weight: 950;
}

.status-sub {
  margin-top: 10rpx;
  color: #dce6ff;
  font-size: 26rpx;
}

.status-sync {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 23rpx;
  font-weight: 700;
}

.sync-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #15d982;
  box-shadow: 0 0 0 8rpx rgba(21, 217, 130, 0.14);
}

.status-sync.syncing .sync-dot {
  background: #ffd36a;
  box-shadow: 0 0 0 8rpx rgba(255, 211, 106, 0.18);
}

.status-price {
  font-size: 38rpx;
  font-weight: 950;
}

.mini-map {
  height: 260rpx;
  position: relative;
  overflow: hidden;
  background: #eaf0f7;
}

.route-road {
  position: absolute;
  height: 42rpx;
  border-radius: 24rpx;
  background: #fff;
  border: 4rpx solid #dce5f2;
}

.road-one {
  width: 660rpx;
  left: -64rpx;
  top: 102rpx;
  transform: rotate(-14deg);
}

.road-two {
  width: 540rpx;
  left: 170rpx;
  top: 134rpx;
  transform: rotate(24deg);
}

.point,
.bike {
  position: absolute;
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 900;
  box-shadow: 0 10rpx 22rpx rgba(20, 28, 50, 0.16);
}

.start { left: 76rpx; top: 128rpx; background: #ff1712; }
.end { right: 82rpx; top: 90rpx; background: #10c779; }
.bike { left: 330rpx; top: 104rpx; background: #13213d; border-radius: 50%; }

.map-mask {
  position: absolute;
  left: 26rpx;
  right: 26rpx;
  bottom: 22rpx;
  height: 58rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.88);
  color: #13213d;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 800;
}

.timeline-card,
.info-card,
.merchant-card {
  padding: 30rpx;
}

.quote-confirm-card {
  padding: 30rpx;
  border: 2rpx solid #ffd9bd;
  background: linear-gradient(180deg, #fffaf5, #ffffff);
}

.quote-confirm-head,
.quote-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.quote-confirm-head {
  flex-direction: column;
  justify-content: center;
  gap: 12rpx;
  text-align: center;
}

.quote-title-group {
  flex: 1;
  min-width: 0;
}

.quote-title-group .section-title {
  color: #111c34;
  font-size: 34rpx;
  letter-spacing: 0;
}

.quote-title-group .section-sub {
  max-width: none;
  line-height: 1.45;
}

.quote-confirm-pill {
  flex-shrink: 0;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  color: #a44b0b;
  background: #ffead8;
  font-size: 22rpx;
  font-weight: 900;
}

.quote-confirm-pill.ACCEPTED {
  color: #087a53;
  background: #dcfbed;
}

.quote-confirm-pill.REJECTED {
  color: #b42318;
  background: #ffe8e5;
}

.quote-waiting,
.quote-final,
.quote-result {
  margin-top: 26rpx;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fff;
  box-shadow: inset 0 0 0 2rpx rgba(255, 184, 126, 0.28);
}

.quote-final {
  text-align: center;
}

.quote-waiting-label,
.quote-result-note,
.quote-note-content {
  color: #7a8498;
  font-size: 24rpx;
  line-height: 1.55;
}

.quote-waiting-price {
  margin-top: 8rpx;
  color: #f04400;
  font-size: 48rpx;
  font-weight: 950;
}

.quote-waiting-price text {
  margin-right: 4rpx;
  font-size: 28rpx;
}

.quote-progress-line {
  margin-top: 12rpx;
  color: #344054;
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 24rpx;
  font-weight: 850;
}

.quote-progress-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #f97316;
  box-shadow: 0 0 0 8rpx rgba(249, 115, 22, 0.12);
}

.quote-waiting-note {
  margin-top: 10rpx;
  color: #68738a;
  font-size: 24rpx;
  line-height: 1.55;
}

.quote-price-grid {
  display: grid;
  grid-template-columns: minmax(0, 1fr) 38rpx minmax(0, 1fr);
  align-items: center;
  gap: 10rpx;
}

.quote-price-block {
  min-width: 0;
  padding: 20rpx 16rpx;
  border-radius: 16rpx;
  background: #f5f7fa;
  text-align: center;
}

.quote-price-block.final {
  color: #fff;
  background: linear-gradient(145deg, #ff7b00, #f23818);
  box-shadow: 0 12rpx 24rpx rgba(242, 72, 24, 0.2);
}

.quote-price-label,
.quote-price-caption {
  display: block;
}

.quote-price-label {
  color: #667085;
  font-size: 22rpx;
  font-weight: 850;
}

.quote-price-amount {
  margin-top: 6rpx;
  color: #111c34;
  font-size: 38rpx;
  font-weight: 950;
  white-space: nowrap;
}

.quote-price-amount text {
  margin-right: 2rpx;
  font-size: 23rpx;
}

.quote-price-caption {
  margin-top: 4rpx;
  color: #98a2b3;
  font-size: 18rpx;
}

.quote-price-block.final .quote-price-label,
.quote-price-block.final .quote-price-amount,
.quote-price-block.final .quote-price-caption {
  color: #fff;
}

.quote-price-block.final .quote-price-caption {
  color: rgba(255, 255, 255, 0.76);
}

.quote-price-arrow {
  color: #f97316;
  font-size: 34rpx;
  font-weight: 950;
  text-align: center;
}

.quote-note,
.quote-warning {
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
  border-radius: 16rpx;
  background: #f7f8fb;
}

.quote-warning {
  color: #8a3c08;
  background: #fff3e8;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
}

.quote-note-label {
  color: #344054;
  font-size: 22rpx;
  font-weight: 950;
}

.quote-note-content {
  margin-top: 6rpx;
  text-align: center;
}

.quote-warning-icon {
  width: 38rpx;
  height: 38rpx;
  border-radius: 50%;
  color: #fff;
  background: #f97316;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 23rpx;
  font-weight: 950;
  flex-shrink: 0;
}

.quote-warning-title {
  font-size: 23rpx;
  font-weight: 950;
  text-align: left;
}

.quote-warning-sub {
  margin-top: 4rpx;
  color: #a85c25;
  font-size: 20rpx;
  text-align: left;
}

.quote-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
  margin-top: 24rpx;
  width: 100%;
}

.quote-button {
  width: 100%;
  min-width: 0;
  max-width: 100%;
  height: 98rpx;
  margin: 0;
  padding: 0 10rpx;
  border: 2rpx solid transparent;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  line-height: 1.2;
  overflow: hidden;
  transition: transform 120ms ease, opacity 120ms ease;
}

.quote-reject {
  color: #344054;
  border-color: #d9e0ea;
  background: linear-gradient(180deg, #ffffff, #f5f7fa);
  box-shadow: 0 8rpx 20rpx rgba(32, 45, 70, 0.07);
}

.quote-accept {
  color: #fff;
  background: linear-gradient(100deg, #ff7b00, #ff3d18 58%, #f31212);
  box-shadow: 0 14rpx 28rpx rgba(245, 62, 24, 0.25);
}

.quote-button-icon {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 950;
  flex-shrink: 0;
}

.reject-icon {
  color: #667085;
  background: #e9edf3;
}

.accept-icon {
  color: #f33a19;
  background: #fff;
}

.quote-button-copy {
  width: auto;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  overflow: hidden;
}

.quote-button-title,
.quote-button-sub {
  max-width: 100%;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.quote-button-title {
  font-size: 24rpx;
  font-weight: 950;
}

.quote-button-sub {
  margin-top: 4rpx;
  color: #8a94a8;
  font-size: 17rpx;
  font-weight: 700;
}

.quote-accept .quote-button-sub {
  color: rgba(255, 255, 255, 0.78);
}

.quote-button-pressed {
  transform: scale(0.98);
  opacity: 0.86;
}

.quote-button[disabled] {
  opacity: 0.58;
}

.quote-result-title {
  color: #111c34;
  font-size: 29rpx;
  font-weight: 950;
}

.quote-result {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.quote-result-icon {
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 950;
  flex-shrink: 0;
}

.quote-result-icon.rejected {
  color: #b42318;
  background: #fee4e2;
}

.quote-result-icon.accepted {
  color: #087a53;
  background: #d1fadf;
}

.quote-result-copy {
  flex: 1;
  min-width: 0;
}

.quote-result-price {
  margin-top: 5rpx;
  color: #087a53;
  font-size: 36rpx;
  font-weight: 950;
}

.quote-result-note {
  margin-top: 10rpx;
}

.quote-result.accepted {
  box-shadow: inset 0 0 0 2rpx rgba(16, 166, 109, 0.22);
}

.timeline {
  margin-top: 26rpx;
  display: flex;
  justify-content: space-between;
}

.step {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #98a1b3;
  position: relative;
}

.step:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 62%;
  top: 23rpx;
  width: 76%;
  height: 4rpx;
  background: #e3e8f2;
}

.step.active:not(:last-child)::after {
  background: #ff655f;
}

.dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #e8edf6;
  color: #8a94a8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 900;
  z-index: 2;
}

.step.active .dot {
  color: #fff;
  background: #ff1712;
}

.step-text {
  margin-top: 14rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.step.active .step-text {
  color: #111c34;
}

.cancel-tip {
  margin-top: 24rpx;
  padding: 18rpx;
  border-radius: 18rpx;
  background: #fff2f1;
  color: #ff1d16;
  font-size: 25rpx;
}

.merchant-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
}

.section-sub {
  margin-top: 8rpx;
  color: #8b95a8;
  font-size: 24rpx;
}

.merchant-pill {
  flex-shrink: 0;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  color: #ff1d16;
  background: #fff1ef;
  font-size: 24rpx;
  font-weight: 900;
}

.merchant-flow {
  margin-top: 28rpx;
  display: flex;
  justify-content: space-between;
}

.merchant-step {
  width: 25%;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  color: #98a1b3;
}

.merchant-step:not(:last-child)::after {
  content: '';
  position: absolute;
  left: 62%;
  top: 21rpx;
  width: 76%;
  height: 4rpx;
  background: #e3e8f2;
}

.merchant-step.active:not(:last-child)::after {
  background: #ff8848;
}

.merchant-dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #e8edf6;
  color: #8a94a8;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 21rpx;
  font-weight: 900;
  z-index: 2;
}

.merchant-step.active .merchant-dot {
  color: #fff;
  background: linear-gradient(135deg, #ff8a00, #ff170f);
}

.merchant-label {
  margin-top: 12rpx;
  font-size: 23rpx;
  font-weight: 800;
}

.merchant-step.active .merchant-label {
  color: #111c34;
}

.merchant-primary,
.merchant-done {
  margin-top: 28rpx;
  height: 82rpx;
  border-radius: 42rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 900;
}

.merchant-primary {
  color: #fff;
  background: linear-gradient(90deg, #ff8a00, #ff170f);
  box-shadow: 0 14rpx 28rpx rgba(255, 53, 20, 0.18);
}

.merchant-done {
  color: #10a66d;
  background: #ecfff6;
}

.info-row {
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 26rpx;
  color: #68738a;
}

.info-row text:last-child {
  color: #111c34;
  font-weight: 800;
  max-width: 440rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  padding: 18rpx 30rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  display: flex;
  align-items: center;
  gap: 18rpx;
  box-shadow: 0 -12rpx 36rpx rgba(20, 28, 50, 0.07);
}

.outline,
.solid {
  height: 84rpx;
  border-radius: 44rpx;
  font-size: 28rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.outline {
  width: 178rpx;
  color: #5f6b82;
  background: #f2f5fa;
}

.solid {
  flex: 1;
  color: #fff;
  background: linear-gradient(90deg, #ff7b00, #ff160c 72%, #f80505);
}
