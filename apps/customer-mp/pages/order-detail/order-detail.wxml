<view class="detail-page" wx:if="{{order}}">
  <view style="height: {{statusBarHeight}}px"></view>
  <view class="page-nav">
    <view class="back" bindtap="goBack">‹</view>
    <view class="nav-title">订单详情</view>
    <view class="nav-action sync-action" bindtap="manualSync">{{isSyncing ? '同步中' : '刷新'}}</view>
  </view>

  <view class="status-hero">
    <view>
      <view class="status-name">{{order.status}}</view>
      <view class="status-sub">{{order.rider}} · {{order.eta}}</view>
      <view class="status-sync {{isSyncing ? 'syncing' : ''}}">
        <view class="sync-dot"></view>
        <text>{{syncText}}</text>
      </view>
    </view>
    <view class="status-price">{{order.feeText}}</view>
  </view>

  <view class="mini-map card">
    <view class="route-road road-one"></view>
    <view class="route-road road-two"></view>
    <view class="point start">发</view>
    <view class="point end">收</view>
    <view class="bike">骑</view>
    <view class="map-mask">{{order.pickupName}} → {{order.dropoffName}}</view>
  </view>

  <view class="card timeline-card">
    <view class="section-title">配送进度</view>
    <view class="timeline">
      <block wx:for="{{statusFlow}}" wx:key="*this">
        <view class="step {{activeIndex >= index && order.status !== '已取消' ? 'active' : ''}}">
          <view class="dot">{{activeIndex > index ? '✓' : index + 1}}</view>
          <view class="step-text">{{item}}</view>
        </view>
      </block>
    </view>
    <view class="cancel-tip" wx:if="{{order.status === '已取消'}}">该订单已取消，可返回首页重新下单。</view>
  </view>

  <view class="card quote-confirm-card" wx:if="{{order.isManualQuote}}">
    <view class="quote-confirm-head">
      <view>
        <view class="section-title">价格确认</view>
        <view class="section-sub">下单前预估仅供参考，最终价格由商家报价</view>
      </view>
      <view class="quote-confirm-pill {{order.quoteStatus}}">{{order.quoteStatusText}}</view>
    </view>

    <view class="quote-waiting" wx:if="{{order.quoteStatus === 'PENDING'}}">
      <view class="quote-waiting-label">规则预估价</view>
      <view class="quote-waiting-price">￥{{order.estimatedFee}}</view>
      <view class="quote-waiting-note">商家正在结合实际需求确定最终价格，报价后需要你再次确认。</view>
    </view>

    <view class="quote-final" wx:elif="{{order.quoteStatus === 'QUOTED'}}">
      <view class="quote-compare"><text>下单前预估</text><text>￥{{order.estimatedFee}}</text></view>
      <view class="quote-compare final"><text>商家最终报价</text><text>￥{{order.quotedFee || order.fee}}</text></view>
      <view class="quote-note" wx:if="{{order.quoteNote}}">{{order.quoteNote}}</view>
      <view class="quote-warning">接受后订单才会进入接单和履约流程</view>
      <view class="quote-actions">
        <button class="quote-reject" disabled="{{isQuoteResponding}}" bindtap="rejectQuote">拒绝报价</button>
        <button class="quote-accept" loading="{{isQuoteResponding}}" disabled="{{isQuoteResponding}}" bindtap="confirmQuote">接受并继续</button>
      </view>
    </view>

    <view class="quote-result rejected" wx:elif="{{order.quoteStatus === 'REJECTED'}}">
      <view class="quote-result-title">你已拒绝本次报价</view>
      <view class="quote-result-note">商家可以根据实际情况重新报价，新的价格仍需你确认。</view>
    </view>

    <view class="quote-result accepted" wx:elif="{{order.quoteStatus === 'ACCEPTED'}}">
      <view class="quote-result-title">已接受商家报价 ￥{{order.quotedFee || order.fee}}</view>
      <view class="quote-result-note">价格已确认，运营人员现在可以继续处理订单。</view>
    </view>
  </view>

  <view class="card merchant-card" wx:if="{{isMerchantMode && order.service === '帮买'}}">
    <view class="merchant-head">
      <view>
        <view class="section-title">商家履约</view>
        <view class="section-sub">录屏演示可直接推进商家接单、备货、交付</view>
      </view>
      <view class="merchant-pill">{{merchantStatus}}</view>
    </view>
    <view class="merchant-flow">
      <block wx:for="{{merchantStatusFlow}}" wx:key="status">
        <view class="merchant-step {{merchantActiveIndex >= index ? 'active' : ''}}">
          <view class="merchant-dot">{{merchantActiveIndex > index ? '✓' : index + 1}}</view>
          <view class="merchant-label">{{item.label}}</view>
        </view>
      </block>
    </view>
    <button class="merchant-primary" wx:if="{{merchantActionText}}" bindtap="advanceMerchantOrder">{{merchantActionText}}</button>
    <view class="merchant-done" wx:else>商家履约已完成</view>
  </view>

  <view class="card info-card">
    <view class="info-row"><text>订单编号</text><text>{{order.id}}</text></view>
    <view class="info-row"><text>服务类型</text><text>{{order.service}}</text></view>
    <view class="info-row" wx:if="{{order.service === '帮买'}}"><text>代买商品</text><text>{{order.buyItems}}</text></view>
    <view class="info-row" wx:if="{{order.service === '帮买'}}"><text>商品价格</text><text>￥{{order.productFee}}</text></view>
    <view class="info-row" wx:if="{{order.service === '帮买'}}"><text>购买地址</text><text>{{order.purchaseAddressName}}</text></view>
    <view class="info-row" wx:if="{{order.service === '帮买'}}"><text>配送费</text><text>￥{{order.deliveryFee}}</text></view>
    <view class="info-row" wx:if="{{order.service === '帮买'}}"><text>应付合计</text><text>￥{{order.fee}}</text></view>
    <view class="info-row" wx:if="{{order.service !== '帮买'}}"><text>物品类型</text><text>{{order.item}}</text></view>
    <view class="info-row" wx:if="{{order.service !== '帮买' && order.vehicleName}}"><text>配送工具</text><text>{{order.vehicleName}}</text></view>
    <view class="info-row" wx:if="{{order.service !== '帮买' && order.weightLabel}}"><text>物品重量</text><text>{{order.weightLabel}}</text></view>
    <view class="info-row" wx:if="{{order.isManualQuote}}"><text>规则预估价</text><text>￥{{order.estimatedFee}}</text></view>
    <view class="info-row" wx:if="{{order.quoteStatus === 'QUOTED' || order.quoteStatus === 'ACCEPTED' || order.quoteStatus === 'REJECTED'}}"><text>商家报价</text><text>￥{{order.quotedFee || order.fee}}</text></view>
    <view class="info-row" wx:if="{{order.quoteNote}}"><text>报价说明</text><text>{{order.quoteNote}}</text></view>
    <view class="info-row"><text>配送距离</text><text>{{order.distance}}km</text></view>
    <view class="info-row"><text>下单时间</text><text>{{order.createTime}}</text></view>
  </view>

  <view class="action-bar">
    <button class="outline" bindtap="cancelOrder" wx:if="{{order.status !== '已完成' && order.status !== '已取消'}}">取消订单</button>
    <button class="outline" bindtap="callRider">联系配送员</button>
    <button class="solid" bindtap="advanceMerchantOrder" wx:if="{{isMerchantMode && merchantActionText}}">{{merchantActionText}}</button>
  </view>
</view>
