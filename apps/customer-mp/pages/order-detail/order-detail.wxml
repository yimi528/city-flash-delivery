<view class="detail-page" wx:if="{{order}}">
  <view style="height: {{statusBarHeight}}px"></view>
  <view class="page-nav">
    <view class="back" bindtap="goBack">‹</view>
    <view class="nav-title">订单详情</view>
    <view class="nav-action sync-action" bindtap="manualSync">{{isSyncing ? '同步中' : '刷新'}}</view>
  </view>

  <view class="status-hero">
    <view>
      <view class="status-name">{{order.displayStatus}}</view>
      <view class="status-sub">{{order.rider}} · {{order.eta}}</view>
      <view class="status-sync {{isSyncing ? 'syncing' : ''}}">
        <view class="sync-dot"></view>
        <text>{{syncText}}</text>
      </view>
    </view>
    <view class="status-price">{{order.feeText}}</view>
  </view>

  <view class="mini-map card">
    <map
      class="order-map"
      latitude="{{mapLatitude}}"
      longitude="{{mapLongitude}}"
      scale="{{mapScale}}"
      markers="{{mapMarkers}}"
      polyline="{{mapPolyline}}"
      include-points="{{mapIncludePoints}}"
      enable-zoom
      enable-scroll
      enable-rotate="{{false}}"
      enable-overlooking="{{false}}"
      bindmarkertap="onMapMarkerTap"
    >
      <cover-view class="map-top-badge">腾讯地图</cover-view>
      <cover-view class="map-route-label">{{mapRouteText}}</cover-view>
      <cover-view class="map-address-label">{{order.pickupName}} → {{order.dropoffName}}</cover-view>
      <cover-view class="map-empty-label" wx:if="{{!mapPointCount}}">订单暂无完整坐标，先显示福鼎市地图</cover-view>
    </map>
  </view>

  <view class="card timeline-card">
    <view class="section-title">配送进度</view>
    <view class="timeline">
      <block wx:for="{{statusFlow}}" wx:key="*this">
        <view class="step {{activeIndex >= index && order.status !== '已取消' ? 'active' : ''}}">
          <view class="dot">{{activeIndex > index ? '✓' : index + 1}}</view>
          <view class="step-text">{{item}}</view>
        </view>
      </block>
    </view>
    <view class="cancel-tip" wx:if="{{order.status === '已取消'}}">该订单已取消，可返回首页重新下单。</view>
  </view>

  <view class="card quote-confirm-card" wx:if="{{order.isManualQuote && order.status !== '已取消'}}">
    <view class="quote-confirm-head">
      <view class="quote-title-group">
        <view class="section-title">核对最终报价</view>
        <view class="section-sub">确认价格并完成支付后，平台将安排本次服务</view>
      </view>
      <view class="quote-confirm-pill {{order.quoteStatus}}">{{order.quoteStatus === 'PENDING' ? '核价中' : (order.quoteStatus === 'QUOTED' ? '待确认' : (order.quoteStatus === 'ACCEPTED' ? '已确认' : '已拒绝'))}}</view>
    </view>

    <view class="quote-waiting" wx:if="{{order.quoteStatus === 'PENDING'}}">
      <view class="quote-waiting-label">当前参考价</view>
      <view class="quote-waiting-price"><text>￥</text>{{order.estimatedFee}}</view>
      <view class="quote-progress-line"><view class="quote-progress-dot"></view><text>商家正在核算现场服务价格</text></view>
      <view class="quote-waiting-note">报价完成后会在此展示，你确认接受后订单才会继续。</view>
    </view>

    <view class="quote-final" wx:elif="{{order.quoteStatus === 'QUOTED'}}">
      <view class="quote-price-grid">
        <view class="quote-price-block estimate">
          <text class="quote-price-label">规则预估</text>
          <view class="quote-price-amount"><text>￥</text>{{order.estimatedFee}}</view>
          <text class="quote-price-caption">下单前参考价格</text>
        </view>
        <view class="quote-price-arrow">→</view>
        <view class="quote-price-block final">
          <text class="quote-price-label">商家报价</text>
          <view class="quote-price-amount"><text>￥</text>{{order.quotedFee || order.fee}}</view>
          <text class="quote-price-caption">本次最终服务价</text>
        </view>
      </view>
      <view class="quote-note" wx:if="{{order.quoteNote}}">
        <view class="quote-note-label">报价说明</view>
        <view class="quote-note-content">{{order.quoteNote}}</view>
      </view>
      <view class="quote-warning">
        <view class="quote-warning-icon">!</view>
        <view>
          <view class="quote-warning-title">请确认是否接受本次报价</view>
          <view class="quote-warning-sub">确认接受后，订单将进入支付环节</view>
        </view>
      </view>
      <view class="quote-actions">
        <button class="quote-button quote-reject" hover-class="quote-button-pressed" disabled="{{isQuoteResponding}}" bindtap="rejectQuote">
          <view class="quote-button-icon reject-icon">×</view>
          <view class="quote-button-copy">
            <text class="quote-button-title">暂不接受</text>
            <text class="quote-button-sub">请商家调整价格</text>
          </view>
        </button>
        <button class="quote-button quote-accept" hover-class="quote-button-pressed" disabled="{{isQuoteResponding}}" bindtap="confirmQuote">
          <view class="quote-button-icon accept-icon">{{isQuoteResponding ? '…' : '✓'}}</view>
          <view class="quote-button-copy">
            <text class="quote-button-title">{{isQuoteResponding ? '正在确认' : '确认接受'}}</text>
            <text class="quote-button-sub">进入支付环节</text>
          </view>
        </button>
      </view>
    </view>

    <view class="quote-result rejected" wx:elif="{{order.quoteStatus === 'REJECTED'}}">
      <view class="quote-result-icon rejected">×</view>
      <view class="quote-result-copy">
        <view class="quote-result-title">本次报价暂未接受</view>
        <view class="quote-result-note">商家调整价格后会重新通知你确认。</view>
      </view>
    </view>

    <view class="quote-result accepted" wx:elif="{{order.quoteStatus === 'ACCEPTED'}}">
      <view class="quote-result-icon accepted">✓</view>
      <view class="quote-result-copy">
        <view class="quote-result-title">最终价格已确认</view>
        <view class="quote-result-price">￥{{order.quotedFee || order.fee}}</view>
        <view class="quote-result-note">{{order.isPaid ? '订单已进入服务安排流程，请留意进度更新。' : '最终价格已确认，请完成支付后开始安排服务。'}}</view>
      </view>
    </view>
  </view>

  <view class="card payment-card" wx:if="{{order.displayStatus === '待支付' && !isMerchantMode}}">
    <view class="payment-copy">
      <view class="payment-kicker">待支付金额</view>
      <view class="payment-amount"><text>￥</text>{{order.fee}}</view>
      <view class="payment-note">支付完成后，订单将进入商家接单流程</view>
    </view>
    <button class="payment-button" disabled="{{isPaying}}" bindtap="payOrder">
      {{isPaying ? '正在支付...' : (isLoggedIn ? '立即支付' : '登录后支付')}}
    </button>
  </view>

  <view class="card merchant-card" wx:if="{{isMerchantMode && order.service === '帮买'}}">
    <view class="merchant-head">
      <view>
        <view class="section-title">商家履约</view>
        <view class="section-sub">录屏演示可直接推进商家接单、备货、交付</view>
      </view>
      <view class="merchant-pill">{{merchantStatus}}</view>
    </view>
    <view class="merchant-flow">
      <block wx:for="{{merchantStatusFlow}}" wx:key="status">
        <view class="merchant-step {{merchantActiveIndex >= index ? 'active' : ''}}">
          <view class="merchant-dot">{{merchantActiveIndex > index ? '✓' : index + 1}}</view>
          <view class="merchant-label">{{item.label}}</view>
        </view>
      </block>
    </view>
    <button class="merchant-primary" wx:if="{{merchantActionText}}" bindtap="advanceMerchantOrder">{{merchantActionText}}</button>
    <view class="merchant-done" wx:else>商家履约已完成</view>
  </view>

  <view class="card info-card">
    <view class="info-row"><text>订单编号</text><text>{{order.id}}</text></view>
    <view class="info-row"><text>支付状态</text><text>{{paymentStatusText}}</text></view>
    <view class="info-row"><text>服务类型</text><text>{{order.service}}</text></view>
    <view class="info-row" wx:if="{{order.service === '帮买'}}"><text>代买商品</text><text>{{order.buyItems}}</text></view>
    <view class="info-row" wx:if="{{order.service === '帮买'}}"><text>商品价格</text><text>￥{{order.productFee}}</text></view>
    <view class="info-row" wx:if="{{order.service === '帮买'}}"><text>购买地址</text><text>{{order.purchaseAddressName}}</text></view>
    <view class="info-row" wx:if="{{order.service === '帮买'}}"><text>配送费</text><text>￥{{order.deliveryFee}}</text></view>
    <view class="info-row" wx:if="{{order.service === '帮买'}}"><text>应付合计</text><text>￥{{order.fee}}</text></view>
    <view class="info-row" wx:if="{{order.service !== '帮买'}}"><text>物品类型</text><text>{{order.item}}</text></view>
    <view class="info-row" wx:if="{{order.service !== '帮买' && order.vehicleName}}"><text>配送工具</text><text>{{order.vehicleName}}</text></view>
    <view class="info-row" wx:if="{{order.service !== '帮买' && order.weightLabel}}"><text>物品重量</text><text>{{order.weightLabel}}</text></view>
    <view class="info-row" wx:if="{{order.isManualQuote}}"><text>规则预估价</text><text>￥{{order.estimatedFee}}</text></view>
    <view class="info-row" wx:if="{{order.quoteStatus === 'QUOTED' || order.quoteStatus === 'ACCEPTED' || order.quoteStatus === 'REJECTED'}}"><text>商家报价</text><text>￥{{order.quotedFee || order.fee}}</text></view>
    <view class="info-row" wx:if="{{order.quoteNote}}"><text>报价说明</text><text>{{order.quoteNote}}</text></view>
    <view class="info-row"><text>配送距离</text><text>{{order.distance}}km</text></view>
    <view class="info-row"><text>下单时间</text><text>{{order.createTime}}</text></view>
  </view>

  <view class="action-bar">
    <button class="outline" disabled="{{isCancelling}}" bindtap="cancelOrder" wx:if="{{canCancel}}">{{isCancelling ? '取消中...' : (canAutoRefundCancellation ? '取消并退款' : (requiresRefundCancellation ? '申请取消' : '取消订单'))}}</button>
    <button class="outline" bindtap="callRider" wx:if="{{order.displayStatus !== '待支付' || isMerchantMode}}">联系配送员</button>
    <button class="solid pay-action" disabled="{{isPaying}}" bindtap="payOrder" wx:if="{{order.displayStatus === '待支付' && !isMerchantMode}}">{{isPaying ? '支付中...' : (isLoggedIn ? '立即支付 ￥' + order.fee : '登录后支付 ￥' + order.fee)}}</button>
    <button class="solid" bindtap="advanceMerchantOrder" wx:if="{{isMerchantMode && merchantActionText}}">{{merchantActionText}}</button>
  </view>
</view>
