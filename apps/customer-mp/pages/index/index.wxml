<view class="safe-page home-page">
  <view style="height: {{statusBarHeight}}px"></view>

  <view class="topbar">
    <view class="brand-lockup">
      <view class="brand-seal">速</view>
      <view>
        <view class="brand">同城速送</view>
        <view class="brand-caption">福鼎本地生活运力</view>
      </view>
    </view>
    <view class="city-chip">
      <view class="city-dot"></view>
      <text>{{city}}</text>
    </view>
  </view>

  <view class="hero-card">
    <view class="hero-copy">
      <view class="hero-kicker">今日运力充足</view>
      <view class="hero-title">从福鼎出发，<br/>人和货都准时到。</view>
      <view class="hero-meta">
        <view><text>1</text> 分钟响应</view>
        <view class="meta-divider"></view>
        <view><text>{{serviceCount}}</text> 项服务</view>
      </view>
    </view>
    <view class="route-art">
      <view class="route-orbit orbit-a"></view>
      <view class="route-orbit orbit-b"></view>
      <view class="route-node node-a"><text>福</text></view>
      <view class="route-node node-b"><text>达</text></view>
      <view class="route-rider">➜</view>
    </view>
    <view class="locate" bindtap="refreshLocation">⌖</view>
  </view>

  <view class="order-panel">
    <view class="panel-head">
      <view>
        <view class="section-kicker">选择服务</view>
        <view class="panel-title">今天要办什么？</view>
      </view>
      <view class="vehicle-pill">{{draft.recommendedVehicleName || '固定车型'}}</view>
    </view>

    <view class="core-task-grid">
      <block wx:for="{{coreTasks}}" wx:key="id">
        <view class="task-card core-task {{draft.taskId === item.id ? 'active' : ''}}" data-task="{{item.id}}" bindtap="chooseTask">
          <view class="task-icon">{{item.icon}}</view>
          <view class="task-copy">
            <view class="task-name">{{item.name}}</view>
            <view class="task-desc">{{item.subtitle}}</view>
          </view>
          <view class="task-check">{{draft.taskId === item.id ? '✓' : ''}}</view>
        </view>
      </block>
    </view>

    <view class="more-head">
      <view class="more-title">更多服务</view>
      <view class="more-line"></view>
    </view>
    <view class="more-task-row">
      <block wx:for="{{moreTasks}}" wx:key="id">
        <view class="more-task {{draft.taskId === item.id ? 'active' : ''}}" data-task="{{item.id}}" bindtap="chooseTask">
          <view class="more-icon">{{item.icon}}</view>
          <view>{{item.name}}</view>
        </view>
      </block>
    </view>

    <view class="price-strip" bindtap="openPricing">
      <view class="price-tag">¥</view>
      <view class="price-main">
        <view class="price-title">{{draft.priceSummary || '按甲方规则计价'}}</view>
        <view class="price-sub">{{draft.taskName}} · {{draft.recommendedVehicleName}} · 后端统一计价</view>
      </view>
      <view class="price-arrow">›</view>
    </view>

    <view class="carpool-flow" wx:if="{{draft.taskId === 'carpool_ride'}}">
      <view class="flow-heading">
        <view class="step-index">1</view>
        <view><view class="flow-title">先选择要去的城市</view><view class="flow-sub">选定后，地址只显示该城市范围</view></view>
      </view>
      <view class="carpool-routes">
        <block wx:for="{{carpoolRoutes}}" wx:key="id">
          <view class="carpool-route {{draft.selectedLine.id === item.id ? 'active' : ''}}" data-route="{{item.id}}" bindtap="chooseCarpoolRoute">
            <view class="route-city">{{item.name}}</view>
            <view class="route-price">¥{{item.price}}/人</view>
            <view class="route-selected">{{draft.selectedLine.id === item.id ? '✓' : ''}}</view>
          </view>
        </block>
      </view>
      <view class="flow-heading address-step">
        <view class="step-index">2</view>
        <view><view class="flow-title">填写{{draft.selectedLine.name}}境内地址</view><view class="flow-sub">可搜索地图，也可手动填写并保存</view></view>
      </view>
    </view>

    <view class="route-group">
      <view class="route-rail">
        <view class="rail-dot start"></view>
        <view class="rail-line"></view>
        <view class="rail-dot end" wx:if="{{draft.taskId !== 'moving_handling' || draft.requiresDelivery}}"></view>
      </view>
      <view class="route-fields">
        <view class="route-row" data-type="pickup" bindtap="chooseAddress">
          <view class="route-main">
            <view class="route-label">{{draft.taskId === 'moving_handling' ? '上门服务地址' : '从哪里出发'}}</view>
            <view class="route-title">{{draft.pickup.name || '选择地址'}}</view>
            <view class="route-sub">{{draft.pickup.detail || draft.pickup.phone}}</view>
          </view>
          <view class="address-book-btn">地址簿</view>
        </view>

        <view class="route-separator" wx:if="{{draft.taskId !== 'moving_handling' || draft.requiresDelivery}}"></view>
        <view class="route-row" wx:if="{{draft.taskId !== 'moving_handling' || draft.requiresDelivery}}" data-type="dropoff" bindtap="chooseAddress">
          <view class="route-main">
            <view class="route-label">送到哪里</view>
            <view class="route-title {{draft.dropoff ? '' : 'placeholder'}}">{{draft.dropoff ? draft.dropoff.name : '选择目的地'}}</view>
            <view class="route-sub" wx:if="{{draft.dropoff}}">{{draft.dropoff.detail}}</view>
          </view>
          <view class="address-book-btn">地址簿</view>
        </view>
      </view>
    </view>

    <view class="handling-home-tip" wx:if="{{draft.taskId === 'moving_handling' && !draft.requiresDelivery}}">
      <text>先预约上门服务</text>，下一步可选择是否需要送往别处
    </view>
    <button class="primary-btn order-btn" bindtap="goOrder">
      <text class="order-btn-label">去下单</text><text class="button-arrow">→</text>
    </button>
    <view class="trust-row">
      <text>平台计价</text><text>·</text><text>骑手认证</text><text>·</text><text>全程可追踪</text>
    </view>
  </view>
</view>
