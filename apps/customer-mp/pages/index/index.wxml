<view class="safe-page home-page">
  <view style="height: {{statusBarHeight}}px"></view>

  <view class="topbar">
    <view class="brand">同城速送</view>
    <view class="city" bindtap="openCity">{{city}} <text class="down">▾</text></view>
    <view class="menu-pill">
      <text>•••</text>
      <view class="pill-dot"></view>
    </view>
  </view>

  <view class="map-card">
    <view class="road road-a"></view>
    <view class="road road-b"></view>
    <view class="road road-c"></view>
    <view class="block block-a"></view>
    <view class="block block-b"></view>
    <view class="block block-c"></view>
    <view class="map-label label-a">福鼎高铁站</view>
    <view class="map-label label-b">华润便利店</view>
    <view class="map-label label-c">4栋</view>
    <view class="accept-bubble"><text>1分钟</text>内接单</view>
    <view class="pin"><view class="pin-head"></view><view class="pin-tail"></view></view>
    <view class="locate" bindtap="refreshLocation">⌖</view>
  </view>

  <view class="order-panel">
    <view class="panel-head">
      <view>
        <view class="panel-title">你要做什么？</view>
        <view class="panel-sub">先选任务，系统自动推荐车型</view>
      </view>
      <view class="vehicle-pill">{{draft.recommendedVehicleName || '推荐车型'}}</view>
    </view>

    <view class="task-grid primary-task-grid">
      <block wx:for="{{primaryTasks}}" wx:key="id">
        <view class="task-card {{draft.taskId === item.id ? 'active' : ''}}" data-task="{{item.id}}" bindtap="chooseTask">
          <view class="task-icon">{{item.icon}}</view>
          <view class="task-name">{{item.name}}</view>
        </view>
      </block>
    </view>

    <view class="price-strip" bindtap="openPricing">
      <view class="price-tag">价</view>
      <view class="price-main">
        <view class="price-title">{{draft.taskName || '寄货'}} · {{draft.priceSummary || '按甲方规则计价'}}</view>
        <view class="price-sub">推荐运力：{{draft.recommendedVehicleName || '小车'}} · {{draft.serviceDesc || '填写地址后下单'}}</view>
      </view>
      <view class="price-arrow">›</view>
    </view>

    <view class="route-row" data-type="pickup" bindtap="chooseAddress">
      <view class="tag-red">起</view>
      <view class="route-main address-field">
        <view class="route-title">{{draft.pickup.name}} <text class="arrow">›</text></view>
        <view class="route-sub">{{draft.pickup.phone}}</view>
      </view>
      <button class="address-book-btn">地址簿</button>
    </view>

    <view class="route-row dropoff" data-type="dropoff" bindtap="chooseAddress">
      <view class="tag-green">到</view>
      <view class="route-main address-field big-input">
        <view class="route-title {{draft.dropoff ? '' : 'placeholder'}}">{{draft.dropoff ? draft.dropoff.name : '目的地/收货地？'}}</view>
        <view class="route-sub" wx:if="{{draft.dropoff}}">{{draft.dropoff.detail}}</view>
      </view>
      <button class="address-book-btn">地址簿</button>
    </view>

    <button class="primary-btn order-btn" bindtap="goOrder">去下单</button>
  </view>

  <view class="card shortcut-card">
    <view class="shortcut-head">
      <view>
        <view class="shortcut-title">常用服务</view>
        <view class="shortcut-sub">取件、代买、搬运与短途送货</view>
      </view>
      <view class="shortcut-more">更省心</view>
    </view>
    <view class="common-grid">
      <block wx:for="{{commonTasks}}" wx:key="id">
        <view class="common-chip {{draft.taskId === item.id ? 'active' : ''}}" data-task="{{item.id}}" bindtap="chooseTask">
          <view class="common-icon">{{item.icon}}</view>
          <view class="common-text">
            <view class="common-name">{{item.name}}</view>
            <view class="common-subtitle">{{item.subtitle}}</view>
          </view>
        </view>
      </block>
    </view>
  </view>
</view>
