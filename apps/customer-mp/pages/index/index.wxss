.home-page {
  padding-bottom: 150rpx;
}

.topbar {
  height: 126rpx;
  padding: 18rpx 32rpx 16rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.brand-lockup {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.brand-seal {
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx 18rpx 18rpx 5rpx;
  color: #fffaf2;
  background: linear-gradient(145deg, var(--cinnabar), var(--cinnabar-strong));
  box-shadow: 0 10rpx 24rpx rgba(185, 47, 32, 0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 31rpx;
  font-weight: 900;
}

.brand {
  color: var(--ink);
  font-family: "Songti SC", "STSong", serif;
  font-size: 37rpx;
  font-weight: 900;
  letter-spacing: -2rpx;
}

.brand-caption {
  margin-top: 2rpx;
  color: #888278;
  font-size: 18rpx;
  letter-spacing: 2rpx;
}

.city-chip {
  height: 58rpx;
  padding: 0 18rpx;
  border: 2rpx solid rgba(24, 32, 29, 0.09);
  border-radius: 30rpx;
  color: #313934;
  background: rgba(255, 253, 248, 0.78);
  box-shadow: 0 8rpx 22rpx rgba(49, 39, 25, 0.05);
  display: flex;
  align-items: center;
  gap: 9rpx;
  font-size: 23rpx;
  font-weight: 750;
}

.city-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--jade);
  box-shadow: 0 0 0 7rpx rgba(40, 116, 92, 0.1);
}

.down {
  color: #918b81;
  font-size: 22rpx;
}

.hero-card {
  height: 310rpx;
  margin: 0 28rpx;
  padding: 38rpx 34rpx;
  position: relative;
  overflow: hidden;
  border-radius: 36rpx;
  color: #fffaf0;
  background:
    radial-gradient(circle at 85% 12%, rgba(222, 150, 84, 0.42), transparent 180rpx),
    linear-gradient(130deg, #1c2722 0%, #25392f 56%, #4a3927 100%);
  box-shadow: 0 24rpx 56rpx rgba(34, 40, 34, 0.18);
  animation: hero-reveal 420ms var(--ease-out) both;
}

.hero-card::after {
  content: '';
  position: absolute;
  inset: 0;
  opacity: 0.16;
  background-image: radial-gradient(rgba(255, 255, 255, 0.75) 1rpx, transparent 1rpx);
  background-size: 20rpx 20rpx;
  pointer-events: none;
}

.hero-copy {
  position: relative;
  z-index: 2;
}

.hero-kicker {
  color: #e9b66f;
  font-size: 20rpx;
  font-weight: 800;
  letter-spacing: 4rpx;
}

.hero-title {
  margin-top: 14rpx;
  font-family: "Songti SC", "STSong", serif;
  font-size: 43rpx;
  font-weight: 900;
  line-height: 1.26;
  letter-spacing: -2rpx;
}

.hero-meta {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  color: rgba(255, 250, 240, 0.68);
  font-size: 20rpx;
}

.hero-meta text {
  color: #f2c17c;
  font-size: 25rpx;
  font-weight: 900;
}

.meta-divider {
  width: 2rpx;
  height: 20rpx;
  background: rgba(255, 255, 255, 0.2);
}

.route-art {
  width: 280rpx;
  height: 280rpx;
  position: absolute;
  right: -18rpx;
  bottom: -18rpx;
  z-index: 1;
}

.route-orbit {
  position: absolute;
  border: 2rpx solid rgba(247, 196, 126, 0.24);
  border-radius: 50%;
}

.orbit-a {
  width: 250rpx;
  height: 130rpx;
  top: 60rpx;
  left: 10rpx;
  transform: rotate(-18deg);
}

.orbit-b {
  width: 210rpx;
  height: 100rpx;
  top: 96rpx;
  left: 32rpx;
  transform: rotate(24deg);
}

.route-node {
  width: 54rpx;
  height: 54rpx;
  position: absolute;
  z-index: 2;
  border: 6rpx solid rgba(255, 253, 248, 0.88);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Songti SC", serif;
  font-size: 20rpx;
  font-weight: 900;
  box-shadow: 0 10rpx 24rpx rgba(0, 0, 0, 0.2);
}

.node-a {
  left: 28rpx;
  top: 126rpx;
  color: #fff;
  background: var(--cinnabar);
}

.node-b {
  right: 20rpx;
  top: 62rpx;
  color: #173025;
  background: #e9b66f;
}

.route-rider {
  position: absolute;
  top: 117rpx;
  left: 130rpx;
  color: #f2c17c;
  font-size: 42rpx;
  transform: rotate(-18deg);
}

.locate {
  position: absolute;
  right: 24rpx;
  bottom: 22rpx;
  z-index: 3;
  width: 60rpx;
  height: 60rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.22);
  border-radius: 22rpx;
  color: #fffaf0;
  background: rgba(16, 25, 21, 0.48);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  transition: transform 140ms var(--ease-out), background-color 140ms ease;
}

.order-panel {
  margin: 22rpx 28rpx 0;
  padding: 34rpx 28rpx 30rpx;
  border: 2rpx solid rgba(24, 32, 29, 0.08);
  border-radius: 34rpx;
  background: var(--paper);
  box-shadow: 0 24rpx 54rpx rgba(48, 39, 27, 0.08);
  animation: panel-reveal 440ms 60ms var(--ease-out) both;
}

.panel-head {
  margin-bottom: 24rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
}

.section-kicker {
  margin-bottom: 7rpx;
  color: var(--cinnabar);
  font-size: 19rpx;
  font-weight: 850;
  letter-spacing: 4rpx;
}

.panel-title {
  color: var(--ink);
  font-family: "Songti SC", "STSong", serif;
  font-size: 40rpx;
  font-weight: 900;
  letter-spacing: -2rpx;
}

.vehicle-pill {
  min-height: 48rpx;
  padding: 0 16rpx;
  border: 2rpx solid rgba(212, 71, 45, 0.16);
  border-radius: 24rpx;
  color: #a93425;
  background: #fff2e8;
  display: flex;
  align-items: center;
  font-size: 20rpx;
  font-weight: 800;
}

.core-task-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 14rpx;
}

.task-card {
  transition: transform 140ms var(--ease-out), border-color 160ms ease, background-color 160ms ease, box-shadow 160ms ease;
}

.core-task {
  min-height: 112rpx;
  padding: 18rpx;
  position: relative;
  border: 2rpx solid rgba(24, 32, 29, 0.09);
  border-radius: 24rpx;
  background: #faf7f0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
}

.core-task.active {
  border-color: rgba(212, 71, 45, 0.46);
  background: #fff3e9;
  box-shadow: 0 12rpx 26rpx rgba(161, 62, 40, 0.08);
}

.task-icon {
  width: 58rpx;
  height: 58rpx;
  flex: 0 0 auto;
  border-radius: 19rpx;
  background: #fffdf9;
  box-shadow: inset 0 0 0 2rpx rgba(24, 32, 29, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
}

.core-task.active .task-icon {
  box-shadow: inset 0 0 0 2rpx rgba(212, 71, 45, 0.14);
}

.task-copy {
  min-width: 0;
  flex: 0 1 auto;
  text-align: center;
}

.task-name {
  color: var(--ink);
  font-size: 27rpx;
  font-weight: 850;
}

.task-desc {
  margin-top: 5rpx;
  color: #888278;
  font-size: 19rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.task-check {
  width: 28rpx;
  height: 28rpx;
  position: absolute;
  top: 10rpx;
  right: 10rpx;
  border-radius: 50%;
  color: #fff;
  background: var(--cinnabar);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 17rpx;
  font-weight: 900;
  opacity: 0;
  transform: scale(0.95);
  transition: opacity 140ms ease, transform 140ms var(--ease-out);
}

.core-task.active .task-check {
  opacity: 1;
  transform: scale(1);
}

.more-head {
  margin: 25rpx 0 15rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.more-title {
  color: #837e74;
  font-size: 20rpx;
  font-weight: 750;
  letter-spacing: 2rpx;
}

.more-line {
  height: 2rpx;
  flex: 1;
  background: rgba(24, 32, 29, 0.08);
}

.more-task-row {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 7rpx;
}

.more-task {
  min-width: 0;
  padding: 10rpx 2rpx;
  border-radius: 18rpx;
  color: #6d716c;
  text-align: center;
  font-size: 18rpx;
  font-weight: 700;
  transition: transform 140ms var(--ease-out), color 140ms ease, background-color 140ms ease;
}

.more-task:active {
  transform: scale(0.96);
}

.more-task.active {
  color: var(--cinnabar-strong);
  background: #fff0e6;
}

.more-icon {
  width: 46rpx;
  height: 46rpx;
  margin: 0 auto 7rpx;
  border-radius: 15rpx;
  background: #f1ede5;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
}

.more-task.active .more-icon {
  background: #fff9f2;
}

.price-strip {
  min-height: 102rpx;
  margin: 26rpx 0 22rpx;
  padding: 17rpx 18rpx;
  border: 2rpx solid rgba(212, 71, 45, 0.13);
  border-radius: 22rpx;
  background: linear-gradient(100deg, #fff2e7, #fffaf3);
  display: flex;
  align-items: center;
  gap: 15rpx;
  transition: transform 140ms var(--ease-out), border-color 140ms ease;
}

.price-tag {
  width: 48rpx;
  height: 48rpx;
  flex: 0 0 auto;
  border-radius: 16rpx;
  color: #fff;
  background: var(--cinnabar);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "DIN Alternate", sans-serif;
  font-size: 25rpx;
  font-weight: 900;
}

.price-main {
  min-width: 0;
  flex: 1;
}

.price-title {
  color: #2b302d;
  font-size: 24rpx;
  font-weight: 850;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.price-sub {
  margin-top: 6rpx;
  color: #8d877e;
  font-size: 19rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.price-arrow {
  color: var(--cinnabar);
  font-size: 38rpx;
}

.route-group {
  padding: 5rpx 18rpx;
  border: 2rpx solid rgba(24, 32, 29, 0.1);
  border-radius: 26rpx;
  background: #fffefa;
  display: flex;
  gap: 14rpx;
}

.route-rail {
  width: 24rpx;
  padding: 35rpx 0;
  display: flex;
  align-items: center;
  flex-direction: column;
}

.rail-dot {
  width: 16rpx;
  height: 16rpx;
  flex: 0 0 auto;
  border: 4rpx solid #fff;
  border-radius: 50%;
  box-shadow: 0 0 0 2rpx currentColor;
}

.rail-dot.start { color: var(--cinnabar); background: var(--cinnabar); }
.rail-dot.end { color: var(--jade); background: var(--jade); }

.rail-line {
  width: 2rpx;
  min-height: 73rpx;
  flex: 1;
  margin: 8rpx 0;
  background: repeating-linear-gradient(to bottom, rgba(24, 32, 29, 0.24) 0, rgba(24, 32, 29, 0.24) 5rpx, transparent 5rpx, transparent 10rpx);
}

.route-fields {
  min-width: 0;
  flex: 1;
}

.route-row {
  min-height: 108rpx;
  padding: 18rpx 0;
  display: flex;
  align-items: center;
  gap: 12rpx;
  transition: transform 140ms var(--ease-out), opacity 140ms ease;
}

.route-main {
  min-width: 0;
  flex: 1;
}

.route-label {
  margin-bottom: 5rpx;
  color: #999287;
  font-size: 18rpx;
  letter-spacing: 1rpx;
}

.route-title {
  color: var(--ink);
  font-size: 28rpx;
  font-weight: 850;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.route-title.placeholder {
  color: #7c7f79;
}

.route-sub {
  margin-top: 5rpx;
  color: #908a81;
  font-size: 19rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.route-separator {
  height: 2rpx;
  background: rgba(24, 32, 29, 0.08);
}

.address-book-btn {
  padding: 10rpx 13rpx;
  border-radius: 14rpx;
  color: #656a65;
  background: #f2eee6;
  font-size: 18rpx;
  font-weight: 750;
  white-space: nowrap;
}

.handling-home-tip {
  margin: 16rpx 0 0;
  padding: 15rpx 18rpx;
  border-radius: 18rpx;
  color: #7f633c;
  background: #fff4dc;
  font-size: 20rpx;
  line-height: 1.5;
}

.handling-home-tip text {
  color: #513f28;
  font-weight: 850;
}

.order-btn {
  position: relative;
  width: 100%;
  box-sizing: border-box;
  margin-top: 24rpx;
  padding: 0 80rpx;
  justify-content: center;
  flex-wrap: nowrap;
  white-space: nowrap;
  font-size: 29rpx;
}

.order-btn-label {
  display: inline-block;
  flex: 0 0 auto;
  text-align: center;
  white-space: nowrap;
  line-height: 1;
}

.button-arrow {
  font-family: "Avenir Next", sans-serif;
  font-size: 36rpx;
  font-weight: 500;
  position: absolute;
  top: 50%;
  right: 30rpx;
  transform: translateY(-50%);
}

.trust-row {
  margin-top: 17rpx;
  color: #9a958c;
  display: flex;
  justify-content: center;
  gap: 10rpx;
  font-size: 18rpx;
  white-space: nowrap;
}

@keyframes hero-reveal {
  from { opacity: 0; transform: translateY(14rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@keyframes panel-reveal {
  from { opacity: 0; transform: translateY(18rpx); }
  to { opacity: 1; transform: translateY(0); }
}

@media (prefers-reduced-motion: reduce) {
  .hero-card,
  .order-panel {
    animation: none;
  }

  .task-card,
  .more-task,
  .price-strip,
  .route-row,
  .locate {
    transition: opacity 120ms ease;
  }
}
