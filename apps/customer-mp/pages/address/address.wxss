.address-page {
  min-height: 100vh;
  padding-bottom: 56rpx;
  background: #f6f7f9;
}

.page-nav {
  height: 96rpx;
  padding: 0 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back {
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  background: #fff;
  color: #121c34;
  font-size: 54rpx;
  line-height: 56rpx;
  text-align: center;
  box-shadow: 0 8rpx 22rpx rgba(18, 28, 52, 0.06);
}

.nav-title {
  font-size: 34rpx;
  font-weight: 900;
  color: #111c34;
}

.nav-add {
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  color: #ff1d16;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 42rpx;
  font-weight: 500;
  line-height: 1;
  box-shadow: 0 8rpx 22rpx rgba(18, 28, 52, 0.06);
}

.search-card {
  height: 88rpx;
  margin: 8rpx 30rpx 0;
  padding: 0 16rpx 0 26rpx;
  border-radius: 26rpx;
  background: #fff;
  display: flex;
  align-items: center;
  gap: 14rpx;
  box-shadow: 0 10rpx 28rpx rgba(22, 30, 50, 0.06);
}

.search-icon {
  color: #9099ad;
  font-size: 40rpx;
}

.search-card input {
  flex: 1;
  height: 88rpx;
  font-size: 28rpx;
  color: #111c34;
}

.search-locate {
  height: 58rpx;
  min-width: 112rpx;
  padding: 0 16rpx;
  border-radius: 30rpx;
  color: #f04432;
  background: #fff2ef;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  font-size: 23rpx;
  font-weight: 900;
}

.search-locate-icon {
  font-size: 29rpx;
  font-weight: 900;
  line-height: 1;
}

.map-picker-card {
  margin: 18rpx 30rpx 0;
  padding: 18rpx 20rpx;
  border-radius: 26rpx;
  border: 2rpx solid #e8edf4;
  background: #fff;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 10rpx 26rpx rgba(18, 28, 52, 0.04);
}

.map-picker-visual {
  position: relative;
  width: 76rpx;
  height: 76rpx;
  flex: 0 0 auto;
  overflow: hidden;
  border-radius: 20rpx;
  background: #eef5fb;
}

.map-grid {
  position: absolute;
  width: 120rpx;
  height: 2rpx;
  background: rgba(92, 145, 177, 0.28);
  transform: rotate(-28deg);
}

.map-grid-one { top: 24rpx; left: -18rpx; }
.map-grid-two { top: 52rpx; left: -12rpx; transform: rotate(34deg); }

.map-picker-icon {
  position: absolute;
  top: 22rpx;
  left: 27rpx;
  width: 24rpx;
  height: 30rpx;
  border-radius: 50% 50% 50% 4rpx;
  background: #f04432;
  transform: rotate(-45deg);
  box-shadow: 0 6rpx 12rpx rgba(240, 68, 50, 0.24);
}

.map-picker-dot {
  position: absolute;
  top: 7rpx;
  left: 7rpx;
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: #fff;
}

.location-copy {
  min-width: 0;
  flex: 1;
}

.location-title {
  color: #111c34;
  font-size: 28rpx;
  font-weight: 900;
}

.map-provider {
  margin-left: 10rpx;
  padding: 4rpx 10rpx;
  border-radius: 12rpx;
  color: #28745c;
  background: #eef8f1;
  font-size: 19rpx;
  font-weight: 800;
}

.location-sub {
  margin-top: 6rpx;
  overflow: hidden;
  color: #8791a5;
  font-size: 23rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.map-picker-action {
  min-width: 88rpx;
  height: 56rpx;
  padding: 0 16rpx;
  border-radius: 30rpx;
  color: #f04432;
  background: #fff2ef;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 23rpx;
  font-weight: 900;
}

.current-card {
  margin: 16rpx 30rpx 0;
  padding: 22rpx;
  border-radius: 24rpx;
  border-left: 6rpx solid #f04432;
  background: #fff;
  display: flex;
  align-items: center;
  gap: 22rpx;
  box-shadow: 0 10rpx 28rpx rgba(18, 28, 52, 0.05);
}

.list-header {
  margin: 30rpx 34rpx 0;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #111c34;
  font-size: 28rpx;
  font-weight: 900;
}

.list-sub {
  color: #8791a5;
  font-size: 23rpx;
  font-weight: 650;
}

.address-list { margin-top: 8rpx; }

.recent-list { margin-top: 6rpx; }

.recent-item {
  border: 2rpx solid rgba(240, 68, 50, 0.12);
  background: linear-gradient(145deg, #fff, #fff8f5);
}

.frequent-list { margin-top: 6rpx; }

.frequent-item {
  border: 2rpx solid rgba(40, 116, 92, 0.13);
  background: linear-gradient(145deg, #ffffff, #f3f8f4);
}

.pin.frequent { color: #fff; background: #28745c; }
.pin.recent { color: #fff; background: #e46a3e; }
.usage-copy { color: #28745c; font-size: 21rpx; }

.address-item {
  margin: 14rpx 30rpx 0;
  padding: 24rpx;
  border-radius: 24rpx;
  background: #fff;
  display: flex;
  align-items: center;
  gap: 22rpx;
  box-shadow: 0 8rpx 22rpx rgba(18, 28, 52, 0.045);
}

.pin {
  width: 52rpx;
  height: 52rpx;
  border-radius: 16rpx;
  color: #fff;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.pin.pickup { background: #ff1712; }
.pin.dropoff { background: #10c779; }
.pin.purchase { background: #ff7b00; }
.pin.current { background: linear-gradient(135deg, #ff7b00, #ff1d16); }
.pin.map { background: #254b92; }

.address-item.map-result {
  background: linear-gradient(135deg, #fff, #f8fbff);
  box-shadow: 0 12rpx 32rpx rgba(37, 75, 146, 0.07);
}

.info {
  flex: 1;
  min-width: 0;
}

.name {
  color: #111c34;
  font-size: 30rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.name text {
  margin-left: 12rpx;
  color: #ff1e16;
  font-size: 23rpx;
}

.name .default-badge {
  padding: 3rpx 10rpx;
  border-radius: 14rpx;
  background: #fff0ed;
  color: #ff1d16;
  font-size: 20rpx;
  font-weight: 900;
}

.detail,
.person {
  margin-top: 7rpx;
  color: #79849a;
  font-size: 25rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.item-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.edit,
.delete,
.use-current,
.use-map {
  width: 86rpx;
  height: 46rpx;
  border-radius: 14rpx;
  font-size: 23rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.edit {
  border: 2rpx solid #dfe5f1;
  color: #5d6b83;
}

.delete {
  color: #ff1d16;
  background: #fff0ed;
}

.use-current,
.use-map {
  color: #fff;
  background: linear-gradient(90deg, #ff7b00, #ff1d16);
  font-weight: 900;
}

.empty-card {
  margin: 28rpx 30rpx 0;
  min-height: 164rpx;
  border-radius: 26rpx;
  border: 3rpx dashed #d9dfeb;
  background: #fff;
  color: #ff1d16;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 68rpx;
  font-weight: 300;
  line-height: 1;
  box-shadow: 0 12rpx 32rpx rgba(18, 28, 52, 0.05);
}

.nav-add:active,
.search-locate:active,
.map-picker-card:active,
.current-card:active,
.address-item:active,
.empty-card:active { transform: scale(0.98); opacity: 0.86; }

@media (prefers-reduced-motion: reduce) {
  .nav-add:active,
  .search-locate:active,
  .map-picker-card:active,
  .current-card:active,
  .address-item:active,
  .empty-card:active { transform: none; }
}
