<view class="address-page">
  <view style="height: {{statusBarHeight}}px"></view>
  <view class="page-nav">
    <view class="back" bindtap="goBack">‹</view>
    <view class="nav-title">{{title}}</view>
    <view class="nav-add" role="button" aria-label="手动填写地址" bindtap="addAddress">+</view>
  </view>

  <view class="search-card">
    <text class="search-icon">⌕</text>
    <input placeholder="{{isCarpool ? '搜索' + routeName + '境内地点' : '搜索小区、写字楼、门店'}}" value="{{keyword}}" bindinput="onSearch" confirm-type="search" />
    <view class="search-locate" role="button" aria-label="定位当前位置" bindtap="locateCurrent">
      <view class="search-locate-icon">⌖</view>
      <view class="search-locate-label">{{isLocating ? '定位中' : '定位'}}</view>
    </view>
  </view>

  <view class="map-picker-card" role="button" aria-label="打开腾讯地图拖动图钉选点" bindtap="openMapPicker">
    <view class="map-picker-visual">
      <view class="map-grid map-grid-one"></view>
      <view class="map-grid map-grid-two"></view>
      <view class="map-picker-icon">
        <view class="map-picker-dot"></view>
      </view>
    </view>
    <view class="location-copy">
      <view class="location-title">地图选点 <text class="map-provider">腾讯地图</text></view>
      <view class="location-sub">拖动地图，用红色图钉精确选择位置</view>
    </view>
    <view class="map-picker-action">打开</view>
  </view>

  <view class="current-card" wx:if="{{currentAddress && !isCarpool}}" bindtap="chooseCurrent">
    <view class="pin current">定</view>
    <view class="info">
      <view class="name">{{currentAddress.name}} <text>{{currentAddress.distance}}</text></view>
      <view class="detail">{{currentAddress.detail}}</view>
      <view class="person">点击使用当前位置作为{{type === 'pickup' ? '发货' : (type === 'purchase' ? '购买' : '收货')}}地址</view>
    </view>
    <view class="use-current">使用</view>
  </view>

  <view class="list-header" wx:if="{{recentAddresses.length}}">
    <view>最近填写</view>
    <view class="list-sub">一键选择刚刚保存的地址</view>
  </view>

  <view class="address-list recent-list" wx:if="{{recentAddresses.length}}">
    <block wx:for="{{recentAddresses}}" wx:key="id">
      <view class="address-item recent-item" data-id="{{item.id}}" bindtap="chooseAddress">
        <view class="pin recent">新</view>
        <view class="info">
          <view class="name">{{item.name}} <text>{{item.distance}}</text></view>
          <view class="detail">{{item.detail}}</view>
          <view class="person" wx:if="{{type != 'pickup'}}">{{item.contact}}  {{item.phone}}</view>
        </view>
        <view class="use-map">选择</view>
      </view>
    </block>
  </view>

  <view class="list-header" wx:if="{{frequentAddresses.length}}">
    <view>你常去的</view>
    <view class="list-sub">按使用频率推荐</view>
  </view>

  <view class="address-list frequent-list" wx:if="{{frequentAddresses.length}}">
    <block wx:for="{{frequentAddresses}}" wx:key="id">
      <view class="address-item frequent-item" data-id="{{item.id}}" bindtap="chooseAddress">
        <view class="pin frequent">常</view>
        <view class="info">
          <view class="name">{{item.name}} <text>{{item.distance}}</text> <text wx:if="{{item.isDefault}}" class="default-badge">默认</text></view>
          <view class="detail">{{item.detail}}</view>
          <view class="person" wx:if="{{type != 'pickup'}}">{{item.contact}}  {{item.phone}}<text wx:if="{{item.usageCount}}" class="usage-copy"> · 已使用{{item.usageCount}}次</text></view>
        </view>
        <view class="item-actions">
          <view class="edit" data-id="{{item.id}}" catchtap="editAddress">编辑</view>
          <view class="delete" data-id="{{item.id}}" catchtap="deleteAddress">删除</view>
        </view>
      </view>
    </block>
  </view>

  <view class="list-header">
    <view>{{keyword ? '搜索结果' : (isCarpool ? routeName + '地址推荐' : (frequentAddresses.length ? '其他地址' : '我的地址'))}}</view>
    <view class="list-sub" wx:if="{{isSearching}}">正在搜索腾讯地图...</view>
    <view class="list-sub" wx:elif="{{keyword}}">{{isCarpool ? '仅显示可匹配顺风车线路的地点' : '包含地址簿和地图建议'}}</view>
  </view>

  <view class="address-list">
    <block wx:for="{{addresses}}" wx:key="id">
      <view class="address-item {{item.isMapResult ? 'map-result' : ''}}" data-id="{{item.id}}" bindtap="chooseAddress">
        <view class="pin {{item.isMapResult ? 'map' : pinClass}}">{{item.isMapResult ? '图' : pinLabel}}</view>
        <view class="info">
          <view class="name">{{item.name}} <text>{{item.distance}}</text> <text wx:if="{{item.isDefault}}" class="default-badge">默认</text></view>
          <view class="detail">{{item.detail}}</view>
          <view class="person" wx:if="{{type != 'pickup'}}"><text wx:if="{{item.sourceLabel}}">[{{item.sourceLabel}}] </text>{{item.contact}}  {{item.phone}}</view>
        </view>
        <view class="use-map" wx:if="{{item.isMapResult}}">填写</view>
        <view class="item-actions" wx:else>
          <view class="edit" data-id="{{item.id}}" catchtap="editAddress">编辑</view>
          <view class="delete" data-id="{{item.id}}" catchtap="deleteAddress">删除</view>
        </view>
      </view>
    </block>
  </view>

  <view class="empty-card" wx:if="{{!addresses.length && !frequentAddresses.length && !recentAddresses.length && !isSearching}}" role="button" aria-label="手动填写地址" bindtap="addAddress">+</view>
</view>
