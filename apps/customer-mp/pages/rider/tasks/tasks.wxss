@import "../../../styles/rider-common.wxss";

.tasks-page { padding-top: 24rpx; }
.task-hero { margin-bottom: 26rpx; padding: 30rpx; border: 2rpx solid #e5ecf5; border-radius: 30rpx; background: linear-gradient(145deg, #eef5ff, #fff); box-shadow: 0 14rpx 32rpx rgba(31,45,61,.05); display: flex; align-items: center; justify-content: space-between; gap: 24rpx; }
.hero-kicker { color: #1677ff; font-size: 20rpx; font-weight: 800; }
.hero-title { margin-top: 6rpx; color: #171d28; font-size: 42rpx; line-height: 1.2; font-weight: 900; letter-spacing: -1rpx; }
.hero-sub { max-width: 440rpx; margin-top: 8rpx; color: #7e8998; font-size: 19rpx; line-height: 1.5; }
.task-count { width: 108rpx; height: 108rpx; flex: 0 0 auto; border-radius: 32rpx; color: #1677ff; background: #fff; box-shadow: inset 0 0 0 2rpx #dbe9fb; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; }
.task-count text { font-family: "DIN Alternate", sans-serif; font-size: 40rpx; font-weight: 950; }
.task-count view { margin-top: 3rpx; color: #8490a0; font-size: 17rpx; }
.task-card { padding: 27rpx; }
.task-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 18rpx; }
.order-number { margin-bottom: 6rpx; color: #949dac; font-size: 18rpx; }
.task-title { color: #202734; font-size: 32rpx; font-weight: 900; }
.status-pill { min-height: 42rpx; padding: 4rpx 14rpx; border-radius: 999rpx; color: #0e67d8; background: #eaf3ff; display: flex; align-items: center; justify-content: center; font-size: 19rpx; font-weight: 850; line-height: 1.3; text-align: center; }
.status-pill.arrived { color: #11744d; background: #e7f7ef; }
.status-note { margin-top: 20rpx; padding: 15rpx 17rpx; border-radius: 17rpx; color: #5f6a79; background: #f4f7fa; display: flex; align-items: center; gap: 12rpx; font-size: 20rpx; }
.pulse { width: 12rpx; height: 12rpx; flex: 0 0 auto; border-radius: 50%; background: #1677ff; box-shadow: 0 0 0 6rpx rgba(22,119,255,.09); }
.route-card { margin-top: 20rpx; padding: 8rpx 20rpx; border: 2rpx solid #e8edf3; border-radius: 22rpx; background: #fafbfd; }
.address-row { min-height: 88rpx; display: flex; align-items: center; gap: 15rpx; }
.route-label { width: 40rpx; height: 40rpx; flex: 0 0 auto; border-radius: 13rpx; color: #fff; display: flex; align-items: center; justify-content: center; font-size: 18rpx; font-weight: 900; }
.route-label.pickup { background: #1677ff; }
.route-label.dropoff { background: #18a66a; }
.route-label.service { background: #65758a; }
.address-row > view { min-width: 0; flex: 1; }
.address-row text { display: block; overflow: hidden; color: #303846; font-size: 23rpx; font-weight: 820; text-overflow: ellipsis; white-space: nowrap; }
.address-row text + text { margin-top: 5rpx; color: #949dac; font-size: 18rpx; font-weight: 550; }
.route-divider { height: 2rpx; margin-left: 55rpx; background: #e8edf3; }
.quick-actions { margin-top: 19rpx; display: grid; grid-template-columns: repeat(3, 1fr); gap: 10rpx; }
.quick-actions button { min-width: 0; height: 78rpx; margin: 0; padding: 0 8rpx; border: 2rpx solid #e5eaf1; border-radius: 20rpx; color: #536074; background: #f7f9fb; display: flex; align-items: center; justify-content: center; gap: 8rpx; font-size: 19rpx; font-weight: 800; line-height: 1.25; text-align: center; transition: transform 110ms var(--ease-out), opacity 110ms ease; }
.quick-actions button:active { transform: scale(.96); opacity: .78; }
.action-icon { width: 31rpx; height: 31rpx; border-radius: 10rpx; display: flex; align-items: center; justify-content: center; font-size: 17rpx; font-weight: 900; }
.action-icon.nav { color: #0f69da; background: #e4f0ff; }
.action-icon.phone { color: #11744d; background: #e3f5ec; }
.action-icon.warn { color: #b4423a; background: #fbe8e6; }
.advance-btn { width: 100%; height: 80rpx; margin-top: 18rpx; padding: 0 25rpx; border-radius: 22rpx; color: #fff; background: #1677ff; box-shadow: 0 12rpx 26rpx rgba(22,119,255,.2); display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: 900; line-height: 1.2; text-align: center; transition: transform 110ms var(--ease-out), opacity 110ms ease; }
.advance-btn:active { transform: scale(.98); opacity: .84; }
.empty-icon { width: 80rpx; height: 80rpx; margin: 0 auto 18rpx; border: 2rpx solid #dce9fb; border-radius: 27rpx; background: #edf5ff; display: flex; align-items: center; justify-content: center; }
.empty-icon view { width: 33rpx; height: 25rpx; border: 3rpx solid #1677ff; border-top: 0; border-radius: 0 0 12rpx 12rpx; }
.empty-title { margin-bottom: 5rpx; color: #303846; font-size: 25rpx; font-weight: 900; }

@media (prefers-reduced-motion: reduce) {
  .quick-actions button, .advance-btn { transition: opacity 120ms ease; }
  .quick-actions button:active, .advance-btn:active { transform: none; }
}
