<view class="rider-page tasks-page">
  <view class="task-hero">
    <view><view class="hero-kicker">ACTIVE TASKS</view><view class="hero-title">当前任务</view><view class="hero-sub">一次专注完成一单，路线和联系方式都在卡片里</view></view>
    <view class="task-count"><text>{{tasks.length}}</text><view>进行中</view></view>
  </view>

  <block wx:for="{{tasks}}" wx:key="id">
    <view class="rider-card task-card">
      <view class="task-head">
        <view><view class="order-number">{{item.orderNo || '当前履约单'}}</view><view class="task-title">{{item.serviceName}}</view></view>
        <view class="status-pill {{item.arrivedAt ? 'arrived' : ''}}">{{item.statusText}}</view>
      </view>

      <view class="status-note"><view class="pulse"></view><text>{{item.statusHint}}</text></view>

      <view class="route-card">
        <view class="address-row"><text class="route-label pickup">取</text><view><text>{{item.pickupName}}</text><text>{{item.pickupDetail}}</text></view></view>
        <view class="route-divider"></view>
        <view class="address-row" wx:if="{{item.dropoffName}}"><text class="route-label dropoff">送</text><view><text>{{item.dropoffName}}</text><text>{{item.dropoffDetail}}</text></view></view>
        <view class="address-row" wx:else><text class="route-label service">服</text><view><text>仅上门服务</text><text>无需送往其他地点</text></view></view>
      </view>

      <view class="quick-actions">
        <button data-lat="{{item.navigateLat}}" data-lng="{{item.navigateLng}}" bindtap="navigate"><view class="action-icon nav">↗</view><text>{{item.navigateLabel}}</text></button>
        <button data-phone="{{item.contactPhone}}" bindtap="callUser"><view class="action-icon phone">电</view><text>联系用户</text></button>
        <button data-id="{{item.id}}" bindtap="reportException"><view class="action-icon warn">!</view><text>上报异常</text></button>
      </view>

      <button class="advance-btn" data-id="{{item.id}}" data-status="{{item.status}}" data-arrived="{{item.arrivedAt}}" bindtap="advance"><text>{{item.nextActionText}}</text><text>→</text></button>
    </view>
  </block>

  <view class="rider-empty" wx:if="{{!loading && !tasks.length}}"><view class="empty-icon"><view></view></view><view class="empty-title">暂无进行中的任务</view><view>抢单成功后，任务路线和操作会出现在这里</view></view>

  <view class="rider-nav">
    <view class="rider-nav-item" data-page="hall" bindtap="goRiderPage"><view class="rider-nav-glyph hall"></view><text class="rider-nav-label">抢单</text></view>
    <view class="rider-nav-item active"><view class="rider-nav-glyph tasks"></view><text class="rider-nav-label">任务</text></view>
    <view class="rider-nav-item" data-page="profile" bindtap="goRiderPage"><view class="rider-nav-glyph profile"></view><text class="rider-nav-label">我的</text></view>
  </view>
</view>
