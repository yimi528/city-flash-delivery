<view class="rider-page hall-page">
  <view class="work-hero">
    <view class="hero-top">
      <view><view class="eyebrow">骑手工作台</view><view class="hero-title">接单大厅</view></view>
      <view class="signal {{online ? 'on' : ''}}"><text></text>{{online ? '在线接单中' : '当前已下线'}}</view>
    </view>

    <view class="work-state">
      <view class="state-copy">
        <view class="state-title">{{online ? '正在为你匹配附近订单' : '上线后开始接单'}}</view>
        <view class="state-sub">{{online ? '符合车型与资质的新单每 8 秒刷新' : '需开启位置权限，便于计算取货距离'}}</view>
      </view>
      <button wx:if="{{rider && !online}}" class="online-btn" bindtap="toggleOnline"><text class="online-dot"></text><text>立即上线</text></button>
      <button wx:elif="{{rider}}" class="online-btn on" bindtap="toggleOnline"><text class="online-dot"></text><text>收工</text></button>
    </view>

    <view class="hero-stats" wx:if="{{rider}}">
      <view class="stat"><text>{{orders.length}}</text><view>附近可抢</view></view>
      <view class="stat-divider"></view>
      <view class="stat"><text>{{rider.maxActiveOrders || 1}}</text><view>任务上限</view></view>
      <view class="stat-divider"></view>
      <view class="stat"><text>{{rider.vehicleName || '待配置'}}</text><view>当前车型</view></view>
    </view>
  </view>

  <view class="section-head">
    <view><view class="section-title">附近订单</view><view class="section-sub">按距离和车型为你匹配</view></view>
    <view class="section-count">{{orders.length}} 单</view>
  </view>

  <view class="offline-card" wx:if="{{rider && !online}}">
    <view class="offline-icon"><view></view></view>
    <view class="offline-copy"><view>你还没有上线</view><text>上线后只显示符合车型、服务范围和资质的订单</text></view>
  </view>

  <block wx:for="{{orders}}" wx:key="id">
    <view class="rider-card order-card">
      <view class="order-head">
        <view><view class="service-line"><text class="service">{{item.serviceName}}</text><text class="vehicle-tag">{{item.vehicleName}}</text></view></view>
        <view class="income-wrap"><view class="income-label">预计收入</view><view class="income"><text>¥</text>{{item.expectedIncomeFen / 100}}</view></view>
      </view>

      <view class="distance-banner"><text>距你</text><view>{{item.pickupDistanceKm === null ? '未知' : item.pickupDistanceKm + 'km'}}</view><text>取货</text></view>

      <view class="order-route">
        <view class="route-rail"><text class="pickup-dot"></text><view></view><text class="dropoff-dot"></text></view>
        <view class="route-copy"><view><text>取</text><view>{{item.pickupArea}}</view></view><view><text>送</text><view>{{item.dropoffArea || '仅上门服务'}}</view></view></view>
      </view>

      <view class="order-meta"><text>预计行程 {{item.routeDistanceKm}}km</text><text>·</text><text>抢单后显示完整地址</text></view>
      <button class="claim-btn" data-id="{{item.id}}" bindtap="claim" loading="{{claimingId === item.id}}"><text>{{claimingId === item.id ? '抢单中...' : '立即抢单'}}</text><text class="claim-arrow">→</text></button>
    </view>
  </block>

  <view class="rider-empty" wx:if="{{rider && online && !orders.length}}"><view class="empty-radar"><view></view></view><view class="empty-title">正在扫描附近订单</view><view>新任务会自动出现，也可下拉刷新</view></view>

  <view class="rider-nav">
    <view class="rider-nav-item active"><view class="rider-nav-glyph hall"></view><text class="rider-nav-label">抢单</text></view>
    <view class="rider-nav-item" data-page="tasks" bindtap="goRiderPage"><view class="rider-nav-glyph tasks"></view><text class="rider-nav-label">任务</text></view>
    <view class="rider-nav-item" data-page="profile" bindtap="goRiderPage"><view class="rider-nav-glyph profile"></view><text class="rider-nav-label">我的</text></view>
  </view>
</view>
