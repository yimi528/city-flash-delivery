@import "../../../styles/rider-common.wxss";

.hall-page { padding-top: 0; }
.work-hero {
  margin: 0 -28rpx 30rpx;
  padding: 38rpx 34rpx 32rpx;
  color: #142033;
  background: linear-gradient(180deg, #f2f7ff 0%, #ffffff 100%);
  border-bottom: 2rpx solid #e7edf6;
}
.hero-top { display: flex; align-items: flex-start; justify-content: space-between; gap: 20rpx; }
.eyebrow { color: #778397; font-size: 20rpx; font-weight: 700; }
.hero-title { margin-top: 6rpx; font-size: 46rpx; line-height: 1.15; font-weight: 900; letter-spacing: -2rpx; }
.signal { padding: 10rpx 15rpx; border-radius: 999rpx; color: #7e8999; background: #edf1f6; display: flex; align-items: center; gap: 9rpx; font-size: 19rpx; font-weight: 700; }
.signal text { width: 11rpx; height: 11rpx; border-radius: 50%; background: #aab2bd; }
.signal.on { color: #11744d; background: #e7f7ef; }
.signal.on text { background: #18a66a; box-shadow: 0 0 0 6rpx rgba(24,166,106,.11); }
.work-state { margin-top: 28rpx; display: flex; align-items: center; justify-content: space-between; gap: 22rpx; }
.state-copy { min-width: 0; flex: 1; }
.state-title { color: #202938; font-size: 28rpx; font-weight: 850; }
.state-sub { margin-top: 7rpx; color: #7f8998; font-size: 21rpx; line-height: 1.45; }
.online-btn { min-width: 166rpx; height: 68rpx; margin: 0; padding: 0 24rpx; border-radius: 999rpx; color: #fff; background: #1677ff; box-shadow: 0 10rpx 24rpx rgba(22,119,255,.22); display: flex; align-items: center; justify-content: center; gap: 10rpx; font-size: 23rpx; font-weight: 850; white-space: nowrap; transition: opacity 110ms ease; }
.online-btn.on { color: #c6423a; background: #fff; box-shadow: inset 0 0 0 2rpx #efc8c5; }
.online-btn:active { opacity: .82; }
.online-dot { width: 12rpx; height: 12rpx; border-radius: 50%; background: currentColor; }
.sound-toggle { width: 100%; height: 72rpx; margin: 22rpx 0 0; padding: 0 20rpx; border: 2rpx solid #e5eaf1; border-radius: 20rpx; box-sizing: border-box; color: #778397; background: rgba(255,255,255,.82); display: flex; align-items: center; gap: 14rpx; text-align: left; white-space: nowrap; transition: transform 140ms var(--ease-out), border-color 150ms ease, background-color 150ms ease; }
.sound-toggle:active { transform: scale(.98); }
.sound-toggle.on { color: #176843; border-color: #cbe6d8; background: #edf8f2; }
.sound-copy { min-width: 0; flex: 1; display: flex; align-items: center; gap: 16rpx; white-space: nowrap; }
.sound-title { flex: 0 0 auto; color: #273142; font-size: 22rpx; line-height: 1; font-weight: 850; white-space: nowrap; }
.sound-status { min-width: 0; flex: 1; overflow: hidden; font-size: 19rpx; line-height: 1; font-weight: 700; text-overflow: ellipsis; white-space: nowrap; }
.sound-icon { width: 31rpx; height: 31rpx; position: relative; flex: 0 0 auto; border: 3rpx solid currentColor; border-radius: 50%; }
.sound-icon text { width: 3rpx; height: 11rpx; position: absolute; top: 7rpx; border-radius: 3rpx; background: currentColor; }
.sound-icon text:first-child { left: 8rpx; }
.sound-icon text:last-child { right: 8rpx; }
.sound-switch { width: 52rpx; height: 30rpx; padding: 3rpx; flex: 0 0 auto; border-radius: 999rpx; background: #c7ced8; box-sizing: border-box; transition: background-color 150ms ease; }
.sound-switch text { display: block; width: 24rpx; height: 24rpx; border-radius: 50%; background: #fff; box-shadow: 0 2rpx 7rpx rgba(0,0,0,.16); transform: translateX(0); transition: transform 160ms var(--ease-out); }
.sound-toggle.on .sound-switch { background: #18a66a; }
.sound-toggle.on .sound-switch text { transform: translateX(22rpx); }
.hero-stats { margin-top: 28rpx; display: grid; grid-template-columns: repeat(3, 1fr); gap: 12rpx; }
.stat { min-width: 0; padding: 18rpx 8rpx; border-radius: 20rpx; background: #f5f7fa; text-align: center; }
.stat text { display: block; overflow: hidden; color: #182033; font-family: "DIN Alternate", sans-serif; font-size: 30rpx; font-weight: 900; text-overflow: ellipsis; white-space: nowrap; }
.stat view { margin-top: 5rpx; color: #8a94a3; font-size: 18rpx; }
.stat-divider { display: none; }

.section-head { margin: 0 4rpx 20rpx; display: flex; align-items: flex-end; justify-content: space-between; }
.section-title { color: #171c25; font-size: 36rpx; line-height: 1.2; font-weight: 900; letter-spacing: -1rpx; }
.section-sub { margin-top: 6rpx; color: #8a94a3; font-size: 20rpx; }
.section-count { padding: 9rpx 16rpx; border-radius: 999rpx; color: #4f6075; background: #e9eef5; font-size: 20rpx; font-weight: 800; }
.offline-card { margin-bottom: 20rpx; padding: 24rpx; border: 2rpx solid #e8edf3; border-radius: 26rpx; background: #fff; display: flex; align-items: center; gap: 18rpx; }
.offline-icon { width: 64rpx; height: 64rpx; flex: 0 0 auto; border-radius: 20rpx; background: #edf5ff; display: flex; align-items: center; justify-content: center; }
.offline-icon view { width: 24rpx; height: 24rpx; border: 5rpx solid #1677ff; border-radius: 50%; box-shadow: 0 0 0 7rpx rgba(22,119,255,.08); }
.offline-copy { min-width: 0; flex: 1; }
.offline-copy view { color: #242b36; font-size: 26rpx; font-weight: 850; }
.offline-copy text { display: block; margin-top: 6rpx; color: #8c95a3; font-size: 19rpx; line-height: 1.45; }

.order-card { position: relative; overflow: hidden; }
.order-card::before { content: ''; width: 7rpx; position: absolute; left: 0; top: 24rpx; bottom: 24rpx; border-radius: 0 7rpx 7rpx 0; background: #1677ff; }
.order-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 20rpx; }
.service-line { display: flex; align-items: center; gap: 11rpx; }
.service { color: #1b2230; font-size: 32rpx; font-weight: 900; }
.vehicle-tag { padding: 6rpx 11rpx; border-radius: 11rpx; color: #50637a; background: #edf1f6; font-size: 18rpx; }
.income-wrap { text-align: right; }
.income-label { color: #929baa; font-size: 17rpx; }
.income { margin-top: 3rpx; color: #1677ff; font-family: "DIN Alternate", sans-serif; font-size: 39rpx; font-weight: 950; }
.income text { margin-right: 2rpx; font-size: 22rpx; }
.distance-banner { margin-top: 21rpx; padding: 14rpx 17rpx; border-radius: 17rpx; color: #748093; background: #f4f7fb; display: flex; align-items: baseline; gap: 8rpx; font-size: 19rpx; }
.distance-banner view { color: #172236; font-family: "DIN Alternate", sans-serif; font-size: 29rpx; font-weight: 950; }
.order-route { margin-top: 21rpx; display: flex; gap: 17rpx; }
.route-rail { width: 20rpx; padding-top: 9rpx; display: flex; flex-direction: column; align-items: center; }
.pickup-dot, .dropoff-dot { width: 14rpx; height: 14rpx; border: 4rpx solid #fff; border-radius: 50%; background: #1677ff; box-shadow: 0 0 0 2rpx #1677ff; }
.dropoff-dot { background: #18a66a; box-shadow: 0 0 0 2rpx #18a66a; }
.route-rail view { width: 2rpx; height: 43rpx; margin: 6rpx 0; background: repeating-linear-gradient(to bottom, #c8d0dc 0, #c8d0dc 5rpx, transparent 5rpx, transparent 9rpx); }
.route-copy { min-width: 0; flex: 1; }
.route-copy > view { height: 55rpx; display: flex; align-items: baseline; gap: 12rpx; }
.route-copy > view + view { margin-top: 7rpx; }
.route-copy text { color: #949dac; font-size: 18rpx; }
.route-copy view view { overflow: hidden; color: #303846; font-size: 24rpx; font-weight: 800; text-overflow: ellipsis; white-space: nowrap; }
.order-meta { margin-top: 21rpx; padding-top: 18rpx; border-top: 2rpx solid #edf0f4; color: #8a94a2; display: flex; gap: 9rpx; font-size: 18rpx; }
.claim-btn { height: 78rpx; margin-top: 22rpx; padding: 0 58rpx; position: relative; border-radius: 22rpx; color: #fff; background: #1677ff; box-shadow: 0 12rpx 25rpx rgba(22,119,255,.2); display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: 900; text-align: center; transition: transform 110ms var(--ease-out), opacity 110ms ease; }
.claim-btn:active { transform: scale(.98); opacity: .84; }
.claim-arrow { position: absolute; right: 25rpx; top: 50%; font-size: 32rpx; font-weight: 500; transform: translateY(-50%); }
.empty-radar { width: 82rpx; height: 82rpx; margin: 0 auto 18rpx; position: relative; border: 2rpx solid rgba(22,119,255,.2); border-radius: 50%; background: rgba(22,119,255,.06); }
.empty-radar::before, .empty-radar::after { content: ''; position: absolute; border: 2rpx solid rgba(22,119,255,.2); border-radius: 50%; }
.empty-radar::before { inset: 15rpx; }
.empty-radar::after { inset: 29rpx; background: #1677ff; }
.empty-title { margin-bottom: 5rpx; color: #303846; font-size: 25rpx; font-weight: 900; }

@media (prefers-reduced-motion: reduce) {
  .online-btn, .claim-btn, .sound-toggle, .sound-switch text { transition: opacity 120ms ease; }
  .claim-btn:active, .sound-toggle:active { transform: none; }
}
