@import "../../../styles/rider-common.wxss";

.profile-page { padding-top: 24rpx; }
.profile-hero { padding: 28rpx; border: 2rpx solid #e5ecf5; border-radius: 30rpx; background: linear-gradient(145deg, #eef5ff, #fff); box-shadow: 0 14rpx 34rpx rgba(31,45,61,.06); }
.hero-topline { display: flex; align-items: center; justify-content: space-between; }
.hero-eyebrow { color: #637086; font-size: 21rpx; font-weight: 750; }
.status-pill { padding: 9rpx 14rpx; border-radius: 999rpx; color: #11744d; background: #e7f7ef; display: flex; align-items: center; gap: 9rpx; font-size: 19rpx; font-weight: 800; }
.status-dot { width: 10rpx; height: 10rpx; border-radius: 50%; background: #18a66a; box-shadow: 0 0 0 6rpx rgba(24,166,106,.1); }
.hero-identity { margin-top: 28rpx; display: flex; align-items: center; gap: 20rpx; }
.avatar { width: 90rpx; height: 90rpx; flex: 0 0 auto; border-radius: 27rpx; color: #fff; background: #1677ff; box-shadow: 0 10rpx 24rpx rgba(22,119,255,.2); display: flex; align-items: center; justify-content: center; font-size: 38rpx; font-weight: 950; }
.identity { min-width: 0; flex: 1; }
.name { margin-bottom: 7rpx; overflow: hidden; color: #171d27; font-size: 38rpx; line-height: 1.2; font-weight: 950; text-overflow: ellipsis; white-space: nowrap; }
.hero-caption { color: #7f8998; font-size: 21rpx; }
.role-badge { padding: 9rpx 14rpx; border-radius: 999rpx; color: #0f69da; background: #e7f1ff; font-size: 19rpx; font-weight: 800; white-space: nowrap; }
.hero-footer { margin-top: 27rpx; padding: 18rpx 20rpx; border-radius: 20rpx; background: rgba(255,255,255,.78); display: flex; align-items: center; }
.hero-meta { min-width: 0; flex: 1; }
.hero-meta text { display: block; margin-bottom: 5rpx; color: #8b95a4; font-size: 17rpx; }
.hero-meta view { overflow: hidden; color: #283142; font-size: 23rpx; font-weight: 820; text-overflow: ellipsis; white-space: nowrap; }
.hero-divider { width: 2rpx; height: 44rpx; margin: 0 22rpx; background: #e4eaf1; }
.section-heading { margin: 30rpx 4rpx 16rpx; display: flex; align-items: center; justify-content: space-between; color: #1a202a; font-size: 28rpx; font-weight: 900; }
.section-note { color: #929ba9; font-size: 19rpx; font-weight: 600; }
.section-count { min-width: 38rpx; height: 38rpx; padding: 0 10rpx; border-radius: 999rpx; color: #526278; background: #e9eef5; display: flex; align-items: center; justify-content: center; font-size: 19rpx; }
.overview-card { margin-bottom: 0; padding: 10rpx 16rpx; display: flex; align-items: stretch; }
.metric { min-width: 0; flex: 1; padding: 22rpx 10rpx; text-align: center; }
.metric-divider { width: 2rpx; margin: 18rpx 0; background: #e9edf2; }
.value-line { height: 58rpx; display: flex; align-items: baseline; justify-content: center; gap: 5rpx; }
.value { color: #182131; font-family: "DIN Alternate", "Avenir Next", sans-serif; font-size: 47rpx; font-weight: 950; letter-spacing: -1rpx; }
.value.money { color: #1677ff; }
.value-unit { color: #939dab; font-size: 20rpx; font-weight: 700; }
.metric-label { margin-top: 4rpx; color: #858f9e; font-size: 21rpx; }
.profile-list { margin-bottom: 18rpx; padding: 4rpx 24rpx; }
.record-row { min-height: 104rpx; border-bottom: 2rpx solid #edf0f4; display: flex; align-items: center; gap: 16rpx; }
.record-row:last-child { border-bottom: 0; }
.record-icon { width: 54rpx; height: 54rpx; flex: 0 0 auto; border-radius: 17rpx; color: #1677ff; background: #edf5ff; display: flex; align-items: center; justify-content: center; font-size: 22rpx; font-weight: 950; }
.record-icon.qualification { color: #11744d; background: #e7f7ef; }
.record-icon.work { color: #677589; background: #edf0f4; }
.record-copy { min-width: 0; flex: 1; }
.record-copy text { display: block; color: #282f3b; font-size: 24rpx; font-weight: 820; }
.record-copy text:last-child { margin-top: 5rpx; color: #9aa2af; font-size: 18rpx; font-weight: 550; }
.record-value { max-width: 190rpx; overflow: hidden; color: #566274; font-size: 22rpx; font-weight: 780; text-overflow: ellipsis; white-space: nowrap; }
.record-value.enabled { color: #11744d; }
.vehicle-heading { margin-top: 24rpx; }
.vehicle-editor { margin-bottom: 18rpx; padding: 22rpx; }
.vehicle-options { display: grid; grid-template-columns: 1fr 1fr; gap: 14rpx; }
.vehicle-option { min-height: 68rpx; padding: 0 16rpx; border: 2rpx solid #e6ebf1; border-radius: 18rpx; color: #626d7d; background: #f8fafc; display: flex; align-items: center; gap: 12rpx; font-size: 22rpx; font-weight: 750; transition: transform 110ms var(--ease-out), border-color 110ms ease, background-color 110ms ease; }
.vehicle-option.selected { border-color: #8cbfff; color: #0f69da; background: #edf5ff; }
.vehicle-option:active { transform: scale(.97); }
.vehicle-check { width: 30rpx; height: 30rpx; border: 2rpx solid #c7cfda; border-radius: 9rpx; color: #fff; background: #fff; display: flex; align-items: center; justify-content: center; font-size: 20rpx; font-weight: 900; }
.vehicle-option.selected .vehicle-check { border-color: #1677ff; background: #1677ff; }
.save-vehicles { margin-top: 18rpx; border-radius: 20rpx; color: #fff; background: #1677ff; font-size: 24rpx; font-weight: 850; transition: transform 110ms var(--ease-out), opacity 110ms ease; }
.save-vehicles:active { transform: scale(.98); opacity: .84; }
.switch-user { width: 100%; min-height: 88rpx; margin: 0 0 8rpx; padding: 14rpx 22rpx; border: 2rpx solid #e5eaf1; border-radius: 24rpx; color: #263142; background: #fff; box-shadow: 0 10rpx 28rpx rgba(31,45,61,.05); display: flex; align-items: center; text-align: left; transition: transform 110ms var(--ease-out), opacity 110ms ease; }
.switch-user:active { transform: scale(.98); opacity: .8; }
.switch-glyph { width: 56rpx; height: 56rpx; flex: 0 0 auto; border-radius: 18rpx; color: #1677ff; background: #edf5ff; display: flex; align-items: center; justify-content: center; font-size: 28rpx; font-weight: 850; }
.switch-copy { min-width: 0; flex: 1; margin-left: 17rpx; }
.switch-copy text { display: block; color: #273142; font-size: 26rpx; font-weight: 850; line-height: 1.35; }
.switch-arrow { margin-left: 14rpx; color: #a0a8b4; font-size: 40rpx; font-weight: 300; }
@media (prefers-reduced-motion: reduce) {
  .vehicle-option, .save-vehicles, .switch-user { transition: opacity 120ms ease; }
  .vehicle-option:active, .save-vehicles:active, .switch-user:active { transform: none; }
}
