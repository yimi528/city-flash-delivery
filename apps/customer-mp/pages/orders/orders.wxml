<view class="orders-page">
  <view style="height: {{statusBarHeight}}px"></view>

  <view class="nav-shell">
    <view><view class="nav-eyebrow">MY ORDERS</view><view class="nav-title">订单</view></view>
  </view>

  <scroll-view class="status-scroll" scroll-x="true" show-scrollbar="false" enhanced="true">
    <view class="status-row">
      <block wx:for="{{filters}}" wx:for-item="filterItem" wx:key="key">
        <view class="status-filter {{filter === filterItem.key ? 'active' : ''}}" data-filter="{{filterItem.key}}" bindtap="changeFilter">
          <text>{{filterItem.label}}</text><text class="filter-count" wx:if="{{filterItem.count}}">{{filterItem.count}}</text>
        </view>
      </block>
    </view>
  </scroll-view>

  <view class="order-list" wx:if="{{orders.length}}">
    <block wx:for="{{orders}}" wx:key="id">
      <view class="order-card" data-id="{{item.id}}" bindtap="openOrder">
        <view class="order-head">
          <view>
            <view class="order-kicker">{{item.orderNoText}}</view>
            <view class="service-line"><text class="service">{{item.service}}</text><text class="vehicle-chip">{{item.vehicleName || '默认车型'}}</text></view>
          </view>
          <view class="status {{item.tone}}">{{item.displayStatus}}</view>
        </view>

        <view class="status-message {{item.tone}}">
          <view class="message-dot"></view>
          <view>{{item.hint}}</view>
        </view>

        <view class="route-block">
          <view class="route-rail"><view class="dot pickup"></view><view class="line"></view><view class="dot dropoff"></view></view>
          <view class="route-copy">
            <view><text>从</text><view>{{item.pickupName}}</view><text class="route-detail" wx:if="{{item.pickupDetail}}">{{item.pickupDetail}}</text></view>
            <view><text>到</text><view>{{item.dropoffName || '仅上门服务'}}</view><text class="route-detail" wx:if="{{item.dropoffDetail}}">{{item.dropoffDetail}}</text></view>
          </view>
        </view>

        <view class="order-foot">
          <view class="order-summary">
            <view>{{item.summaryText}}</view>
            <text>{{item.createTime}}</text>
          </view>
          <view class="amount-wrap"><text class="amount-label">{{item.needsQuote ? '预估' : '合计'}}</text><text class="fee">{{item.feeText}}</text></view>
        </view>
      </view>
    </block>
  </view>

  <view class="empty-panel" wx:else>
    <view class="empty-mark"><view class="empty-road"></view><view class="empty-pin">单</view></view>
    <view class="empty-title">{{filter === 'ALL' ? '还没有订单' : '这里暂时没有订单'}}</view>
    <view class="empty-copy">下单后，报价、接单和配送进度都会在这里更新</view>
    <button class="empty-btn" bindtap="goHome">去下单</button>
  </view>
</view>
