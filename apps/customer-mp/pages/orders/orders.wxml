<view class="orders-page">
  <view style="height: {{statusBarHeight}}px"></view>

  <view class="nav-shell">
    <view class="nav-title">订单列表</view>
    <view class="menu-pill"><text>•••</text><view class="pill-dot"></view></view>
  </view>

  <view class="mode-row">
    <view class="mode {{mode === '寄' ? 'active' : ''}}" data-mode="寄" bindtap="changeMode">我寄的</view>
    <view class="mode {{mode === '收' ? 'active' : ''}}" data-mode="收" bindtap="changeMode">我收的</view>
    <view class="invoice" bindtap="openInvoice">开发票</view>
  </view>

  <scroll-view class="status-scroll" scroll-x="true" show-scrollbar="false">
    <view class="status-row">
      <block wx:for="{{filters}}" wx:key="*this">
        <view class="status-filter {{filter === item ? 'active' : ''}}" data-filter="{{item}}" bindtap="changeFilter">{{item}}</view>
      </block>
    </view>
  </scroll-view>

  <view class="order-list" wx:if="{{orders.length}}">
    <block wx:for="{{orders}}" wx:key="id">
      <view class="order-card" data-id="{{item.id}}" bindtap="openOrder">
        <view class="order-head">
          <view class="service">{{item.service}}</view>
          <view class="status {{item.displayStatus === '已完成' ? 'done' : ''}}">{{item.displayStatus}}</view>
        </view>
        <view class="route">
          <view class="dot red"></view>
          <view class="route-name">{{item.pickupName}}</view>
        </view>
        <view class="route">
          <view class="dot green"></view>
          <view class="route-name">{{item.dropoffName}}</view>
        </view>
        <view class="order-foot">
          <text wx:if="{{item.service === '帮买'}}">{{item.buyItems || item.item}} · 商品￥{{item.productFee}} + 配送￥{{item.deliveryFee}} · {{item.createTime}}</text>
          <text wx:else>{{item.item}} · {{item.vehicleName || '二轮电动'}} · {{item.distance}}km · {{item.createTime}}</text>
          <text class="fee">{{item.feeText}}</text>
        </view>
      </view>
    </block>
  </view>

  <view class="empty-panel" wx:else>
    <view class="sign-art">
      <view class="post"></view>
      <view class="board top"></view>
      <view class="board mid"></view>
      <view class="board bot"></view>
      <view class="leaf"></view>
      <view class="shadow"></view>
    </view>
    <view class="empty-copy">轻按查看2026年订单</view>
    <button class="empty-btn" bindtap="goHome">去下一单</button>
  </view>
</view>
