.confirm-page {
  min-height: 100vh;
  padding-bottom: 158rpx;
  background: linear-gradient(180deg, #fff0f0 0%, #f4f6fb 360rpx, #f4f6fb 100%);
}

.page-nav {
  height: 92rpx;
  padding: 0 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.78);
  color: #121c34;
  font-size: 58rpx;
  line-height: 58rpx;
  text-align: center;
}

.nav-title {
  font-size: 34rpx;
  font-weight: 900;
}

.nav-action {
  color: #ff1d16;
  font-size: 28rpx;
  font-weight: 800;
}

.route-card {
  padding: 30rpx;
}

.service-badge {
  display: inline-flex;
  height: 52rpx;
  padding: 0 22rpx;
  border-radius: 28rpx;
  background: #fff0ed;
  color: #ff1d16;
  font-size: 24rpx;
  font-weight: 850;
  align-items: center;
  margin-bottom: 20rpx;
}

.route-meter {
  margin: -8rpx 0 22rpx;
  color: #7b879b;
  font-size: 24rpx;
  font-weight: 750;
}

.route-line {
  display: flex;
  gap: 20rpx;
  align-items: center;
}

.route-info {
  flex: 1;
  min-width: 0;
}

.title {
  color: #111c34;
  font-size: 32rpx;
  font-weight: 900;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.sub {
  margin-top: 8rpx;
  color: #7c879c;
  font-size: 25rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.connector {
  width: 4rpx;
  height: 42rpx;
  margin: 8rpx 0 8rpx 22rpx;
  background: linear-gradient(180deg, #ff1712, #10c779);
  border-radius: 4rpx;
}

.connector.buy {
  background: linear-gradient(180deg, #ff7b00, #10c779);
}

.tag-buy {
  width: 46rpx;
  height: 46rpx;
  border-radius: 14rpx;
  color: #fff;
  background: #ff7b00;
  font-size: 26rpx;
  font-weight: 800;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.option-card,
.price-card,
.cargo-card,
.line-card,
.buy-card {
  padding: 30rpx;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

.section-head .muted {
  font-size: 23rpx;
}

.line-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
}

.line-option {
  min-height: 112rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: #f7f9fd;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
  box-shadow: inset 0 0 0 2rpx rgba(229, 234, 244, 0.82);
}

.line-option.active {
  background: #fff6ed;
  box-shadow: inset 0 0 0 3rpx rgba(255, 121, 0, 0.24);
}

.line-name {
  color: #111c34;
  font-size: 29rpx;
  font-weight: 950;
}

.line-price {
  color: #ff1d16;
  font-size: 31rpx;
  font-weight: 950;
}

.limit-banner {
  margin-bottom: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 20rpx;
  background: #fff8ea;
  color: #a76200;
  font-size: 24rpx;
  font-weight: 850;
}

.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.chip,
.weight {
  min-width: 142rpx;
  height: 62rpx;
  padding: 0 22rpx;
  border-radius: 18rpx;
  background: #f5f7fb;
  color: #566176;
  font-size: 26rpx;
  font-weight: 750;
  display: flex;
  align-items: center;
  justify-content: center;
}

.chip.active,
.weight.active {
  color: #ff1d16;
  background: #fff0ed;
  box-shadow: inset 0 0 0 3rpx rgba(255, 29, 22, 0.18);
}

.weight-row {
  margin-top: 28rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  color: #111c34;
  font-size: 28rpx;
  font-weight: 850;
}

.weight-list {
  display: flex;
  gap: 12rpx;
}

.weight {
  min-width: 82rpx;
  height: 54rpx;
  border-radius: 16rpx;
  font-size: 24rpx;
}

textarea {
  width: 100%;
  min-height: 92rpx;
  margin-top: 28rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: #f6f8fc;
  color: #111c34;
  font-size: 26rpx;
}

.buy-card textarea {
  min-height: 126rpx;
  font-size: 28rpx;
  line-height: 1.55;
}

.buy-budget-row {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #f1f3f8;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.buy-budget-title {
  color: #111c34;
  font-size: 29rpx;
  font-weight: 900;
}

.buy-budget-sub {
  margin-top: 8rpx;
  color: #7c879c;
  font-size: 23rpx;
}

.buy-budget-input {
  width: 172rpx;
  height: 64rpx;
  padding: 0 18rpx;
  border-radius: 34rpx;
  background: #fff0ed;
  color: #ff1d16;
  font-size: 28rpx;
  font-weight: 950;
  display: flex;
  align-items: center;
}

.buy-budget-input input {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  color: #ff1d16;
  font-size: 30rpx;
  font-weight: 950;
}

.edit-link {
  color: #ff1d16;
  font-size: 25rpx;
  font-weight: 850;
}

.cargo-summary {
  min-height: 116rpx;
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: #f7f9fd;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.cargo-visual {
  position: relative;
  width: 118rpx;
  height: 86rpx;
  border-radius: 18rpx;
  background: #fff;
  flex-shrink: 0;
  overflow: hidden;
}

.cargo-body {
  position: absolute;
  left: 12rpx;
  bottom: 20rpx;
  width: 82rpx;
  height: 36rpx;
  border-radius: 22rpx;
  background: rgba(205, 216, 232, 0.68);
}

.etrike .cargo-body {
  width: 94rpx;
  height: 40rpx;
  border-radius: 14rpx 20rpx 14rpx 14rpx;
}

.cargo_tricycle .cargo-body,
.human_tricycle .cargo-body {
  width: 94rpx;
  height: 40rpx;
  border-radius: 14rpx 20rpx 14rpx 14rpx;
}

.van .cargo-body,
.car .cargo-body {
  width: 96rpx;
  height: 42rpx;
  border-radius: 20rpx 30rpx 14rpx 14rpx;
}

.small_car .cargo-body {
  width: 96rpx;
  height: 42rpx;
  border-radius: 20rpx 30rpx 14rpx 14rpx;
}

.ebike .cargo-body {
  left: 20rpx;
  width: 62rpx;
  height: 32rpx;
}

.cargo-box {
  position: absolute;
  right: 16rpx;
  bottom: 32rpx;
  width: 38rpx;
  height: 34rpx;
  border-radius: 6rpx;
  background: linear-gradient(135deg, #ff877e, #ff2118);
}

.etrike .cargo-box {
  right: 12rpx;
  width: 42rpx;
  height: 40rpx;
}

.cargo_tricycle .cargo-box,
.human_tricycle .cargo-box {
  right: 12rpx;
  width: 42rpx;
  height: 40rpx;
}

.van .cargo-box,
.car .cargo-box {
  right: 10rpx;
  width: 44rpx;
  height: 44rpx;
}

.small_car .cargo-box {
  right: 10rpx;
  width: 44rpx;
  height: 44rpx;
}

.ebike .cargo-box {
  right: 18rpx;
  bottom: 34rpx;
  width: 28rpx;
  height: 30rpx;
}

.cargo-info {
  flex: 1;
  min-width: 0;
}

.cargo-name {
  color: #101b36;
  font-size: 30rpx;
  font-weight: 950;
}

.cargo-desc {
  margin-top: 8rpx;
  color: #7d879b;
  font-size: 23rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cargo-fee {
  min-width: 76rpx;
  height: 46rpx;
  padding: 0 14rpx;
  border-radius: 24rpx;
  background: #fff0ed;
  color: #ff1d16;
  font-size: 23rpx;
  font-weight: 900;
  display: flex;
  align-items: center;
  justify-content: center;
}

.vehicle-inline {
  margin-top: 22rpx;
  padding: 16rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, #ffffff, #f6f8fd);
  box-shadow: inset 0 0 0 2rpx rgba(226, 232, 244, 0.88);
}

.vehicle-inline-head {
  padding: 8rpx 6rpx 16rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 16rpx;
}

.vehicle-inline-title {
  color: #101b36;
  font-size: 29rpx;
  font-weight: 950;
}

.vehicle-inline-tip {
  color: #8a94a8;
  font-size: 22rpx;
  font-weight: 750;
}

.vehicle-row {
  min-height: 128rpx;
  padding: 18rpx 18rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.vehicle-row + .vehicle-row {
  margin-top: 8rpx;
}

.vehicle-row.active {
  background: #fff7ed;
  box-shadow: inset 0 0 0 3rpx rgba(255, 121, 0, 0.18);
}

.vehicle-icon {
  width: 76rpx;
  height: 76rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #eef3fb, #ffffff);
  color: #111c34;
  font-size: 28rpx;
  font-weight: 950;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 10rpx 24rpx rgba(26, 38, 64, 0.08);
}

.vehicle-icon.cargo_tricycle,
.vehicle-icon.human_tricycle {
  background: linear-gradient(135deg, #fff1dc, #ffffff);
  color: #db6500;
}

.vehicle-icon.ebike {
  background: linear-gradient(135deg, #eafff4, #ffffff);
  color: #09a66f;
}

.vehicle-icon.manual_labor {
  background: linear-gradient(135deg, #edf4ff, #ffffff);
  color: #2d65d8;
}

.vehicle-main {
  flex: 1;
  min-width: 0;
}

.vehicle-line {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.vehicle-name {
  color: #101b36;
  font-size: 29rpx;
  font-weight: 950;
}

.vehicle-tag {
  padding: 4rpx 10rpx;
  border-radius: 12rpx;
  background: rgba(255, 121, 0, 0.1);
  color: #f06c00;
  font-size: 19rpx;
  font-weight: 900;
}

.vehicle-desc {
  margin-top: 8rpx;
  color: #657086;
  font-size: 23rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.vehicle-capacity {
  margin-top: 4rpx;
  color: #9aa4b6;
  font-size: 21rpx;
  font-weight: 750;
}

.vehicle-price {
  min-width: 92rpx;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
  color: #101b36;
  font-size: 24rpx;
  font-weight: 950;
}

.vehicle-check {
  width: 34rpx;
  height: 34rpx;
  border-radius: 50%;
  background: #ff1d16;
  color: #fff;
  font-size: 22rpx;
  font-weight: 950;
  display: flex;
  align-items: center;
  justify-content: center;
}

.arrival {
  color: #10b775;
  font-size: 24rpx;
  font-weight: 850;
}

.price-row {
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #69748a;
  font-size: 27rpx;
}

.price-row text:last-child {
  color: #111c34;
  font-weight: 850;
}

.price-row.discount text:last-child {
  color: #ff1d16;
}

.price-row.service-fee {
  margin-top: 8rpx;
  padding-top: 10rpx;
  border-top: 2rpx solid #f1f3f8;
}

.price-row.service-fee text:last-child,
.price-row.budget-fee text:last-child {
  color: #ff1d16;
}

.weather-row {
  margin-top: 18rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: #fff8ea;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.weather-title {
  color: #111c34;
  font-size: 27rpx;
  font-weight: 900;
}

.weather-sub {
  margin-top: 6rpx;
  color: #a76200;
  font-size: 23rpx;
  font-weight: 750;
}

.switch {
  width: 92rpx;
  height: 52rpx;
  padding: 4rpx;
  border-radius: 30rpx;
  background: #d6deeb;
  display: flex;
  align-items: center;
  justify-content: flex-start;
  flex-shrink: 0;
  transition: all 0.2s ease;
}

.switch.on {
  background: linear-gradient(90deg, #ff8a00, #ff1d16);
  justify-content: flex-end;
}

.switch-dot {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #fff;
  box-shadow: 0 6rpx 14rpx rgba(42, 52, 74, 0.16);
}

.guarantee {
  margin-top: 20rpx;
  padding: 20rpx;
  border-radius: 20rpx;
  background: #f3fffa;
  display: flex;
  gap: 18rpx;
  align-items: center;
}

.check {
  width: 42rpx;
  height: 42rpx;
  border-radius: 50%;
  border: 3rpx solid #c8d0df;
  color: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
}

.check.checked {
  border-color: #10c779;
  color: #fff;
  background: #10c779;
}

.guarantee-title {
  color: #111c34;
  font-size: 27rpx;
  font-weight: 850;
}

.guarantee-sub {
  margin-top: 6rpx;
  color: #6c778d;
  font-size: 23rpx;
}

.submit-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 20;
  min-height: 128rpx;
  padding: 18rpx 30rpx calc(18rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 -12rpx 36rpx rgba(20, 28, 50, 0.07);
}

.amount {
  width: 190rpx;
}

.amount .muted {
  font-size: 23rpx;
}

.money {
  color: #ff1d16;
  font-size: 42rpx;
  font-weight: 950;
}

.pay-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 50rpx;
  color: #fff;
  font-size: 31rpx;
  font-weight: 900;
  background: linear-gradient(90deg, #ff7b00, #ff160c 72%, #f80505);
  display: flex;
  align-items: center;
  justify-content: center;
}
