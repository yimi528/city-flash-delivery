<view class="confirm-page">
  <view style="height: {{statusBarHeight}}px"></view>
  <view class="page-nav">
    <view class="back" bindtap="goBack">‹</view>
    <view class="nav-title">确认订单</view>
    <view class="nav-action">明细</view>
  </view>

  <view class="route-card card">
    <view class="service-badge" wx:if="{{draft.service === '帮买'}}">帮买 · 商品预算 ￥{{estimate.budget}}</view>
    <view class="service-badge" wx:else>{{draft.service}} · 预计 {{estimate.distance}}km</view>
    <view class="route-meter">{{isRouteLoading ? '正在获取腾讯地图距离...' : routeSource}} · {{routeDuration ? '约 ' + routeDuration + ' 分钟' : '预计 ' + estimate.distance + 'km'}}</view>
    <view class="route-line">
      <view class="{{draft.service === '帮买' ? 'tag-buy' : 'tag-red'}}">{{draft.service === '帮买' ? '买' : '发'}}</view>
      <view class="route-info">
        <view class="title">{{draft.pickup.name}}</view>
        <view class="sub" wx:if="{{draft.service === '帮买'}}">购买地址 · {{draft.pickup.detail}}</view>
        <view class="sub" wx:else>{{draft.pickup.detail}} · {{draft.pickup.phone}}</view>
      </view>
    </view>
    <view class="connector {{draft.service === '帮买' ? 'buy' : ''}}"></view>
    <view class="route-line">
      <view class="tag-green">收</view>
      <view class="route-info">
        <view class="title">{{draft.dropoff.name}}</view>
        <view class="sub">{{draft.dropoff.detail}} · {{draft.dropoff.phone}}</view>
      </view>
    </view>
  </view>

  <view class="card buy-card" wx:if="{{draft.service === '帮买'}}">
    <view class="section-head">
      <view class="section-title">代买商品</view>
      <view class="muted">骑手按描述购买</view>
    </view>
    <textarea value="{{draft.buyItems}}" placeholder="请填写品牌、口味、规格、可接受替代方案" auto-height maxlength="120" bindinput="inputBuyItems" />
    <view class="buy-budget-row">
      <view>
        <view class="buy-budget-title">商品预算</view>
        <view class="buy-budget-sub">正式版可接入多退少补和小票上传</view>
      </view>
      <view class="buy-budget-input"><text>￥</text><input type="digit" value="{{draft.budget}}" bindinput="inputBudget" /></view>
    </view>
  </view>

  <view class="card option-card" wx:else>
    <view class="section-head">
      <view class="section-title">物品信息</view>
      <view class="muted">{{draft.service === '送货' ? '用于匹配车型' : '用于骑手判断车辆和保价'}}</view>
    </view>
    <view class="chips">
      <block wx:for="{{itemTypes}}" wx:key="*this">
        <view class="chip {{draft.item === item ? 'active' : ''}}" data-item="{{item}}" bindtap="selectItem">{{item}}</view>
      </block>
    </view>
    <view class="weight-row">
      <text>重量</text>
      <view class="weight-list">
        <block wx:for="{{weights}}" wx:key="*this">
          <view class="weight {{draft.weight === item ? 'active' : ''}}" data-weight="{{item}}" bindtap="selectWeight">{{item}}kg</view>
        </block>
      </view>
    </view>
    <textarea placeholder="备注：如取件码、门牌号、是否需要电话联系" auto-height maxlength="80" bindinput="inputRemark" />
  </view>

  <view class="card cargo-card" wx:if="{{draft.service === '送货'}}" bindtap="openCargoOptions">
    <view class="section-head">
      <view class="section-title">配送工具</view>
      <view class="edit-link">重新选择</view>
    </view>
    <view class="cargo-summary">
      <view class="cargo-visual {{draft.cargoOptions.vehicleId}}">
        <view class="cargo-body"></view>
        <view class="cargo-box"></view>
      </view>
      <view class="cargo-info">
        <view class="cargo-name">{{draft.cargoOptions.vehicleName}}</view>
        <view class="cargo-desc">{{draft.cargoOptions.categoryName}} · {{draft.cargoOptions.weightLabel}} · {{draft.cargoOptions.vehicleCapacity}}</view>
      </view>
      <view class="cargo-fee" wx:if="{{draft.cargoOptions.vehicleFee}}">+￥{{draft.cargoOptions.vehicleFee}}</view>
      <view class="cargo-fee" wx:else>基础</view>
    </view>
  </view>

  <view class="card price-card">
    <view class="section-head">
      <view class="section-title">费用预估</view>
      <view class="arrival">{{draft.service === '帮买' ? '骑手代买' : (draft.service === '送货' ? '车型接送' : (draft.service === '1对1急送' ? '专人直送' : '约20分钟达'))}}</view>
    </view>
    <view class="price-row"><text>{{draft.service === '帮买' ? '跑腿起步价' : '起步价'}}</text><text>￥{{estimate.base}}</text></view>
    <view class="price-row"><text>距离费</text><text>￥{{estimate.distanceFee}}</text></view>
    <view class="price-row" wx:if="{{draft.service !== '帮买'}}"><text>重量费</text><text>￥{{estimate.weightFee}}</text></view>
    <view class="price-row" wx:if="{{draft.service === '送货'}}"><text>车型费</text><text>￥{{estimate.vehicleFee}}</text></view>
    <view class="price-row" wx:if="{{draft.service === '1对1急送'}}"><text>急送费</text><text>￥{{estimate.urgentFee}}</text></view>
    <view class="price-row discount"><text>新人优惠</text><text>-￥{{estimate.discount}}</text></view>
    <view class="price-row service-fee" wx:if="{{draft.service === '帮买'}}"><text>跑腿服务费</text><text>￥{{estimate.serviceFee}}</text></view>
    <view class="price-row budget-fee" wx:if="{{draft.service === '帮买'}}"><text>商品预算</text><text>￥{{estimate.budget}}</text></view>
    <view class="guarantee" bindtap="toggleGuarantee">
      <view class="check {{guarantee ? 'checked' : ''}}">✓</view>
      <view>
        <view class="guarantee-title">购买保价服务</view>
        <view class="guarantee-sub">演示版默认展示，可接入真实保价规则。</view>
      </view>
    </view>
  </view>

  <view class="submit-bar">
    <view class="amount">
      <view class="muted">需支付</view>
      <view class="money">￥{{estimate.total}}</view>
    </view>
    <button class="pay-btn" bindtap="submitOrder">微信支付并下单</button>
  </view>
</view>
