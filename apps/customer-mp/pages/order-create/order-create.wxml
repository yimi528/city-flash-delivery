<view class="confirm-page">
  <view style="height: {{statusBarHeight}}px"></view>
  <view class="page-nav">
    <view class="back" bindtap="goBack">‹</view>
    <view class="nav-title">{{draft.taskId === 'moving_handling' ? '搬运装卸' : '确认订单'}}</view>
    <view class="nav-action">明细</view>
  </view>

  <view class="handling-intro" wx:if="{{draft.taskId === 'moving_handling'}}">
    <view class="handling-kicker">一站式搬运</view>
    <view class="handling-title">搬家、搬店和装卸统一下单</view>
    <view class="handling-sub">上门服务固定收费，需要配送时再按驾车距离计费</view>
  </view>

  <view class="card handling-card" wx:if="{{draft.taskId === 'moving_handling'}}">
    <view class="section-head handling-head">
      <view>
        <view class="section-title">本次需要什么服务？</view>
        <view class="handling-hint">选择主要需求，再补充现场情况</view>
      </view>
    </view>
    <view class="handling-options">
      <block wx:for="{{handlingTypes}}" wx:key="name">
        <view class="handling-option {{draft.item === item.name ? 'active' : ''}}" data-item="{{item.name}}" bindtap="selectItem">
          <view class="handling-icon">{{item.icon}}</view>
          <view class="handling-copy">
            <view class="handling-name">{{item.name}}</view>
            <view class="handling-desc">{{item.desc}}</view>
          </view>
          <view class="handling-check">{{draft.item === item.name ? '✓' : ''}}</view>
        </view>
      </block>
    </view>
    <textarea class="handling-remark" value="{{draft.remark}}" placeholder="{{fieldConfig.remarkPlaceholder}}" auto-height maxlength="160" bindinput="inputRemark" />
  </view>

  <view class="card delivery-choice" wx:if="{{draft.taskId === 'moving_handling'}}">
    <view class="delivery-choice-row" bindtap="toggleHandlingDelivery">
      <view>
        <view class="section-title">需要送到别的地方</view>
        <view class="muted">开启后增加目的地，并按驾车距离计算配送费</view>
      </view>
      <switch checked="{{draft.requiresDelivery}}" color="#ff3b30" />
    </view>
    <view class="destination-picker" wx:if="{{draft.requiresDelivery}}" bindtap="chooseHandlingDestination">
      <view>
        <view class="destination-label">配送目的地</view>
        <view class="destination-name">{{draft.dropoff ? draft.dropoff.name : '请选择目的地'}}</view>
      </view>
      <text>›</text>
    </view>
  </view>

  <view class="route-card card">
    <view class="service-badge" wx:if="{{draft.service === '帮买'}}">帮买 · 商品价格 ￥{{estimate.productFee}}</view>
    <view class="service-badge" wx:else>{{draft.service}} · 预计 {{estimate.distance}}km</view>
    <view class="route-meter" wx:if="{{draft.taskId !== 'moving_handling' || draft.requiresDelivery}}">{{isRouteLoading ? '正在获取腾讯地图距离...' : routeSource}} · {{routeDuration ? '约 ' + routeDuration + ' 分钟' : '预计 ' + estimate.distance + 'km'}}</view>
    <view class="route-line">
      <view class="{{draft.service === '帮买' ? 'tag-buy' : 'tag-red'}}">{{draft.service === '帮买' ? '买' : '发'}}</view>
      <view class="route-info">
        <view class="title">{{draft.pickup.name}}</view>
        <view class="sub" wx:if="{{draft.service === '帮买'}}">购买地址 · {{draft.pickup.detail}}</view>
        <view class="sub" wx:else>{{draft.pickup.detail}} · {{draft.pickup.phone}}</view>
      </view>
    </view>
    <view class="connector {{draft.service === '帮买' ? 'buy' : ''}}" wx:if="{{draft.taskId !== 'moving_handling' || draft.requiresDelivery}}"></view>
    <view class="route-line" wx:if="{{draft.taskId !== 'moving_handling' || draft.requiresDelivery}}">
      <view class="tag-green">收</view>
      <view class="route-info">
        <view class="title">{{draft.dropoff.name}}</view>
        <view class="sub">{{draft.dropoff.detail}} · {{draft.dropoff.phone}}</view>
      </view>
    </view>
  </view>

  <view class="card line-card" wx:if="{{taskLines.length}}">
    <view class="section-head">
      <view class="section-title">选择线路</view>
      <view class="muted">{{draft.taskId === 'carpool_ride' ? '单人票价' : '固定价格'}}</view>
    </view>
    <view class="direction-switch" wx:if="{{draft.taskId === 'carpool_ride'}}">
      <view class="direction-option {{draft.direction !== 'RETURN' ? 'active' : ''}}" data-direction="OUTBOUND" bindtap="selectDirection">去程 · 福鼎出发</view>
      <view class="direction-option {{draft.direction === 'RETURN' ? 'active' : ''}}" data-direction="RETURN" bindtap="selectDirection">返程 · 回福鼎</view>
    </view>
    <view class="line-grid">
      <block wx:for="{{taskLines}}" wx:key="id">
        <view class="line-option {{selectedLineId === item.id ? 'active' : ''}}" data-id="{{item.id}}" bindtap="selectLine">
          <view class="line-name">{{item.name}}</view>
          <view class="line-price">￥{{item.price}}{{draft.taskId === 'carpool_ride' ? '/人' : ''}}</view>
        </view>
      </block>
    </view>
  </view>

  <view class="card passenger-card" wx:if="{{draft.taskId === 'carpool_ride'}}">
    <view>
      <view class="section-title">乘车人数</view>
      <view class="muted">7座商务车，最多6名乘客</view>
    </view>
    <view class="passenger-stepper">
      <button data-step="-1" bindtap="changePassenger" disabled="{{passengerCount <= 1}}">−</button>
      <text>{{passengerCount}} 人</text>
      <button data-step="1" bindtap="changePassenger" disabled="{{passengerCount >= 6}}">＋</button>
    </view>
  </view>

  <view class="card buy-card" wx:if="{{draft.service === '帮买'}}">
    <view class="section-head">
      <view class="section-title">代买商品</view>
      <view class="muted">骑手按描述购买</view>
    </view>
    <textarea value="{{draft.buyItems}}" placeholder="请填写品牌、口味、规格、可接受替代方案" auto-height maxlength="120" bindinput="inputBuyItems" />
    <view class="buy-budget-row">
      <view>
        <view class="buy-budget-title">商品价格</view>
        <view class="buy-budget-sub">按预计购买金额计入本次应付合计</view>
      </view>
      <view class="buy-budget-input"><text>￥</text><input type="digit" value="{{draft.budget}}" bindinput="inputBudget" /></view>
    </view>
  </view>

  <view class="card option-card" wx:if="{{draft.service !== '帮买' && draft.taskId !== 'moving_handling' && draft.taskId !== 'carpool_ride'}}">
    <view class="section-head">
      <view class="section-title">{{fieldConfig.sectionTitle}}</view>
      <view class="muted">{{fieldConfig.sectionHint}}</view>
    </view>
    <view class="limit-banner" wx:if="{{fieldConfig.limitText}}">{{fieldConfig.limitText}}</view>
    <view class="chips">
      <block wx:for="{{itemTypes}}" wx:key="*this">
        <view class="chip {{draft.item === item ? 'active' : ''}}" data-item="{{item}}" bindtap="selectItem">{{item}}</view>
      </block>
    </view>
    <view class="weight-row" wx:if="{{fieldConfig.showWeight}}">
      <text>重量</text>
      <view class="weight-list">
        <block wx:for="{{weights}}" wx:key="*this">
          <view class="weight {{draft.weight === item ? 'active' : ''}}" data-weight="{{item}}" bindtap="selectWeight">{{item}}kg</view>
        </block>
      </view>
    </view>
    <textarea placeholder="{{fieldConfig.remarkPlaceholder}}" auto-height maxlength="120" bindinput="inputRemark" />
  </view>

  <view class="card cargo-card">
    <view class="section-head">
      <view class="section-title">固定服务车型</view>
      <view class="muted">下单后不可切换</view>
    </view>
    <view class="cargo-summary">
      <view class="cargo-emoji">{{draft.cargoOptions.icon}}</view>
      <view class="cargo-info">
        <view class="cargo-name">{{draft.cargoOptions.vehicleName}}</view>
        <view class="cargo-desc">{{draft.cargoOptions.categoryName}} · {{draft.taskId === 'moving_handling' ? '按服务类型固定' : draft.cargoOptions.weightLabel}} · {{draft.cargoOptions.vehicleCapacity}}</view>
      </view>
      <view class="cargo-fee" wx:if="{{draft.cargoOptions.vehicleFee}}">+￥{{draft.cargoOptions.vehicleFee}}</view>
      <view class="cargo-fee" wx:else>基础</view>
    </view>
  </view>

  <view class="card price-card">
    <view class="section-head">
      <view class="section-title">费用预估</view>
      <view class="arrival">{{estimate.pricingNote}}</view>
    </view>
    <view class="price-row" wx:if="{{draft.service !== '帮买'}}"><text>{{estimate.baseTitle}}</text><text>{{estimate.baseText}}</text></view>
    <view class="price-row" wx:if="{{draft.service !== '帮买' && estimate.showDistanceFee}}"><text>{{estimate.distanceFeeTitle}}</text><text>￥{{estimate.distanceFee}}</text></view>
    <view class="price-row" wx:if="{{draft.service !== '帮买' && estimate.showWeatherFee}}"><text>恶劣天气加价</text><text>￥{{estimate.weatherFee}}</text></view>
    <view class="price-row" wx:if="{{estimate.showWeightFee}}"><text>重量费</text><text>￥{{estimate.weightFee}}</text></view>
    <view class="price-row" wx:if="{{estimate.showVehicleFee}}"><text>车型费</text><text>￥{{estimate.vehicleFee}}</text></view>
    <view class="price-row" wx:if="{{estimate.showUrgentFee}}"><text>急送费</text><text>￥{{estimate.urgentFee}}</text></view>
    <view class="price-row discount" wx:if="{{estimate.showDiscount}}"><text>{{estimate.discountTitle}}</text><text>-￥{{estimate.discount}}</text></view>
    <view class="price-row budget-fee" wx:if="{{draft.service === '帮买'}}"><text>商品价格</text><text>￥{{estimate.productFee}}</text></view>
    <view class="price-row service-fee" wx:if="{{draft.service === '帮买'}}"><text>配送费</text><text>￥{{estimate.deliveryFee}}</text></view>
    <view class="weather-row {{draft.badWeather ? 'active' : ''}}" wx:if="{{estimate.pricingMode === 'distance_weather'}}">
      <view>
        <view class="weather-title">天气预报自动判断</view>
        <view class="weather-sub">{{isWeatherLoading ? '正在同步天气预报...' : weatherRisk.reason}}</view>
        <view class="weather-meta">{{weatherRisk.weatherText}}</view>
      </view>
      <view class="weather-badge {{draft.badWeather ? 'bad' : ''}}">{{isWeatherLoading ? '同步中' : (draft.badWeather ? '已触发' : '正常')}}</view>
    </view>
    <view class="guarantee" wx:if="{{!estimate.isManualQuote && draft.service !== '拼车'}}" bindtap="toggleGuarantee">
      <view class="check {{guarantee ? 'checked' : ''}}">✓</view>
      <view>
        <view class="guarantee-title">购买保价服务</view>
        <view class="guarantee-sub">演示版默认展示，可接入真实保价规则。</view>
      </view>
    </view>
  </view>

  <view class="submit-bar">
    <view class="amount">
      <view class="muted">需支付</view>
      <view class="money">{{estimate.totalText}}</view>
    </view>
    <button class="pay-btn" disabled="{{isSubmitting}}" bindtap="submitOrder">{{isSubmitting ? '处理中...' : '微信支付并下单'}}</button>
  </view>
</view>
