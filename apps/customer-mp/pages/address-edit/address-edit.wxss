.edit-page {
  min-height: 100vh;
  padding-bottom: calc(54rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, #fff4f2 0%, #f5f6f8 330rpx, #f5f6f8 100%);
}

.page-nav {
  height: 92rpx;
  padding: 0 30rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.back,
.nav-placeholder {
  width: 64rpx;
  height: 64rpx;
  flex: 0 0 auto;
}

.back {
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.86);
  color: #121c34;
  font-size: 58rpx;
  line-height: 58rpx;
  text-align: center;
}

.nav-title {
  color: #111c34;
  font-size: 34rpx;
  font-weight: 900;
}

.smart-card {
  min-height: 112rpx;
  margin: 18rpx 30rpx 0;
  padding: 22rpx 22rpx 22rpx 26rpx;
  border-radius: 28rpx;
  background: #fff;
  display: flex;
  align-items: center;
  gap: 18rpx;
  box-shadow: 0 12rpx 32rpx rgba(18, 28, 52, 0.05);
}

.smart-input {
  min-height: 64rpx;
  max-height: 150rpx;
  flex: 1;
  color: #111c34;
  font-size: 27rpx;
  line-height: 1.45;
}

.recognize-btn {
  min-width: 176rpx;
  height: 62rpx;
  margin: 0;
  padding: 0 22rpx;
  border: 2rpx solid #9aa4b5;
  border-radius: 32rpx;
  color: #303b50;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 800;
  line-height: 1;
}

.recognize-btn::after,
.save-btn::after { border: 0; }

.form-card {
  margin: 24rpx 30rpx 0;
  padding: 0 30rpx;
  border-radius: 30rpx;
  background: #fff;
  box-shadow: 0 14rpx 36rpx rgba(22, 30, 50, 0.06);
}

.scope-lock {
  margin: 0 -4rpx;
  padding: 18rpx 20rpx;
  border-bottom: 2rpx solid #eef0f4;
  color: #25674f;
  background: #eef8f2;
  font-size: 22rpx;
  font-weight: 800;
}

.field-row {
  min-height: 112rpx;
  border-bottom: 2rpx solid #eef0f4;
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.label {
  width: 120rpx;
  flex: 0 0 auto;
  color: #30394a;
  font-size: 28rpx;
  font-weight: 800;
}

.field-input {
  min-width: 0;
  height: 86rpx;
  flex: 1;
  color: #111c34;
  font-size: 28rpx;
}

.locate-inline {
  min-width: 88rpx;
  height: 52rpx;
  padding: 0 14rpx;
  border-radius: 28rpx;
  color: #ff1d16;
  background: #fff0ed;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 23rpx;
  font-weight: 900;
}

.map-loading {
  padding: 18rpx 0;
  border-bottom: 2rpx solid #eef0f4;
  color: #8791a5;
  font-size: 23rpx;
}

.map-results {
  padding-bottom: 8rpx;
  border-bottom: 2rpx solid #eef0f4;
}

.map-result {
  padding: 20rpx 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.map-result + .map-result { border-top: 2rpx solid #f3f4f7; }

.map-pin {
  width: 48rpx;
  height: 48rpx;
  flex: 0 0 auto;
  border-radius: 15rpx;
  color: #ff1d16;
  background: #fff0ed;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 900;
}

.map-info {
  min-width: 0;
  flex: 1;
}

.map-name {
  overflow: hidden;
  color: #182137;
  font-size: 26rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.map-name text {
  margin-left: 8rpx;
  color: #ff1d16;
  font-size: 21rpx;
}

.map-detail {
  margin-top: 6rpx;
  overflow: hidden;
  color: #8a93a5;
  font-size: 22rpx;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.map-use {
  width: 78rpx;
  height: 46rpx;
  border-radius: 24rpx;
  color: #ff1d16;
  background: #fff0ed;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 21rpx;
  font-weight: 900;
}

.tag-section {
  padding: 24rpx 0 20rpx;
  border-bottom: 2rpx solid #eef0f4;
}

.tag-label {
  color: #6d778c;
  font-size: 23rpx;
  font-weight: 800;
}

.tags {
  margin-top: 16rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.tag {
  min-width: 80rpx;
  height: 48rpx;
  padding: 0 16rpx;
  border-radius: 24rpx;
  color: #7b8497;
  background: #f4f6f9;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 23rpx;
}

.tag.active {
  color: #ff1d16;
  background: #fff0ed;
  font-weight: 900;
}

.default-row {
  min-height: 112rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.check {
  width: 42rpx;
  height: 42rpx;
  flex: 0 0 auto;
  border: 3rpx solid #cbd1dc;
  border-radius: 50%;
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 25rpx;
  font-weight: 900;
}

.check.on {
  border-color: #ff1d16;
  background: #ff1d16;
}

.default-copy { min-width: 0; flex: 1; }
.default-title { color: #182137; font-size: 27rpx; font-weight: 850; }
.default-sub { margin-top: 4rpx; color: #939bab; font-size: 21rpx; }

.coordinate-row {
  margin: 0 -30rpx;
  padding: 14rpx 30rpx;
  border-radius: 0 0 30rpx 30rpx;
  color: #5d806f;
  background: #f0f8f4;
  font-size: 21rpx;
  text-align: center;
}

.save-btn {
  height: 94rpx;
  margin: 34rpx 30rpx 0;
  border-radius: 60rpx;
  color: #fff;
  background: linear-gradient(90deg, #ff7b00, #ff160c 72%, #f80505);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 18rpx 34rpx rgba(255, 47, 18, 0.24);
  font-size: 32rpx;
  font-weight: 900;
}

.back:active,
.recognize-btn:active,
.locate-inline:active,
.map-result:active,
.tag:active,
.default-row:active,
.save-btn:active { transform: scale(0.98); opacity: 0.86; }

@media (prefers-reduced-motion: reduce) {
  .back:active,
  .recognize-btn:active,
  .locate-inline:active,
  .map-result:active,
  .tag:active,
  .default-row:active,
  .save-btn:active { transform: none; }
}
