.vehicle-page {
  min-height: 100vh;
  padding-bottom: 160rpx;
  background: #f4f6fb;
  overflow: hidden;
}

.map-backdrop {
  position: relative;
  height: 520rpx;
  overflow: hidden;
}

.vehicle-map {
  width: 100%;
  height: 100%;
}

.map-page-nav {
  position: absolute;
  left: 30rpx;
  right: 30rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.map-top-badge,
.map-route-label,
.map-vehicle-label,
.map-empty-label {
  position: absolute;
  left: 24rpx;
  border-radius: 999rpx;
  padding: 8rpx 16rpx;
  color: #111c34;
  background: rgba(255, 255, 255, 0.92);
  font-size: 19rpx;
  font-weight: 800;
  box-shadow: 0 8rpx 20rpx rgba(20, 28, 50, 0.12);
}

.map-top-badge { top: 112rpx; color: #ff3b30; }
.map-route-label { top: 112rpx; left: auto; right: 24rpx; }
.map-vehicle-label { bottom: 24rpx; right: 24rpx; overflow: hidden; max-width: 82%; text-overflow: ellipsis; white-space: nowrap; }
.map-empty-label { left: 50%; top: 52%; transform: translate(-50%, -50%); white-space: nowrap; color: #6f7c91; }

.left-actions {
  height: 66rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.48);
  display: flex;
  align-items: center;
  overflow: hidden;
  box-shadow: inset 0 0 0 2rpx rgba(255, 255, 255, 0.20);
}

.back,
.home {
  width: 84rpx;
  height: 66rpx;
  color: #05070c;
  font-size: 58rpx;
  line-height: 60rpx;
  text-align: center;
}

.home {
  border-left: 2rpx solid rgba(0, 0, 0, 0.12);
  font-size: 42rpx;
  line-height: 66rpx;
}

.menu-pill {
  width: 168rpx;
  height: 66rpx;
  padding: 0 24rpx;
  border-radius: 40rpx;
  background: rgba(255, 255, 255, 0.76);
  display: flex;
  align-items: center;
  justify-content: space-between;
  color: #111;
  font-size: 34rpx;
}

.pill-dot {
  width: 42rpx;
  height: 42rpx;
  border: 8rpx solid #161922;
  border-radius: 50%;
}

.vehicle-sheet {
  position: relative;
  z-index: 2;
  margin: 0 24rpx;
  padding: 18rpx 22rpx 28rpx;
  border-radius: 38rpx;
  background: rgba(255, 255, 255, 0.98);
  box-shadow: 0 -10rpx 46rpx rgba(16, 36, 66, 0.12);
}

.sheet-handle {
  width: 72rpx;
  height: 8rpx;
  margin: 0 auto 22rpx;
  border-radius: 8rpx;
  background: #d6dce8;
}

.sheet-head {
  padding: 0 10rpx 20rpx;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.sheet-title {
  color: #111c34;
  font-size: 40rpx;
  font-weight: 950;
  letter-spacing: -1rpx;
}

.sheet-sub {
  max-width: 480rpx;
  margin-top: 8rpx;
  color: #8b95aa;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.change-tip {
  height: 44rpx;
  padding: 0 16rpx;
  border-radius: 24rpx;
  color: #ff1712;
  background: #fff0ed;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 21rpx;
  font-weight: 900;
  flex-shrink: 0;
}

.vehicle-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.vehicle-row {
  min-height: 142rpx;
  padding: 20rpx 20rpx;
  border: 3rpx solid #edf1f7;
  border-radius: 28rpx;
  background: #fff;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.vehicle-row.active {
  border-color: #ff1712;
  background: linear-gradient(90deg, #fff7f4, #fff);
  box-shadow: 0 14rpx 28rpx rgba(255, 23, 18, 0.09);
}

.vehicle-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 24rpx;
  color: #fff;
  background: linear-gradient(180deg, #ff8a80, #ff1712);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 950;
  flex-shrink: 0;
}

.vehicle-icon.cargo_tricycle,
.vehicle-icon.human_tricycle {
  background: linear-gradient(180deg, #ffb020, #ff6a00);
}

.vehicle-icon.ebike {
  background: linear-gradient(180deg, #2563eb, #111c34);
}

.vehicle-icon.manual_labor {
  background: linear-gradient(180deg, #10c779, #078f5b);
}

.vehicle-main {
  flex: 1;
  min-width: 0;
}

.vehicle-line {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.vehicle-name {
  color: #111c34;
  font-size: 31rpx;
  font-weight: 950;
}

.vehicle-tag {
  height: 34rpx;
  padding: 0 10rpx;
  border-radius: 18rpx;
  color: #ff1712;
  background: #fff0ed;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 19rpx;
  font-weight: 900;
}

.vehicle-desc {
  margin-top: 8rpx;
  color: #6f7a90;
  font-size: 24rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.vehicle-capacity {
  margin-top: 6rpx;
  color: #9aa4b8;
  font-size: 21rpx;
}

.vehicle-price {
  width: 116rpx;
  text-align: right;
  color: #111c34;
  font-size: 26rpx;
  font-weight: 950;
  flex-shrink: 0;
}

.vehicle-price text {
  display: inline-flex;
  margin-top: 8rpx;
  padding: 3rpx 10rpx;
  border-radius: 999rpx;
  color: #fff;
  background: #ff1712;
  font-size: 18rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9;
  padding: 18rpx 44rpx 42rpx;
  background: linear-gradient(180deg, rgba(244, 246, 251, 0), #f4f6fb 30%);
}

.confirm-btn {
  height: 92rpx;
  border: 0;
  border-radius: 48rpx;
  color: #fff;
  background: linear-gradient(90deg, #ff7a00, #ff1712);
  font-size: 32rpx;
  font-weight: 950;
  box-shadow: 0 18rpx 34rpx rgba(255, 23, 18, 0.24);
}
