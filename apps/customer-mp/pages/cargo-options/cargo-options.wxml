<view class="vehicle-page">
  <view class="map-backdrop">
    <map
      class="vehicle-map"
      latitude="{{mapLatitude}}"
      longitude="{{mapLongitude}}"
      scale="{{mapScale}}"
      markers="{{mapMarkers}}"
      polyline="{{mapPolyline}}"
      include-points="{{mapIncludePoints}}"
      enable-zoom
      enable-scroll
      enable-rotate="{{false}}"
      enable-overlooking="{{false}}"
      bindmarkertap="onMapMarkerTap"
    >
      <cover-view class="map-page-nav" style="top: {{statusBarHeight + 12}}px">
        <cover-view class="left-actions">
          <cover-view class="back" bindtap="goBack">‹</cover-view>
          <cover-view class="home" bindtap="goHome">⌂</cover-view>
        </cover-view>
        <cover-view class="menu-pill"><cover-view>•••</cover-view><cover-view class="pill-dot"></cover-view></cover-view>
      </cover-view>
      <cover-view class="map-top-badge">腾讯地图</cover-view>
      <cover-view class="map-route-label">{{mapRouteText}}</cover-view>
      <cover-view class="map-vehicle-label">{{selectedVehicleName}} · {{routeText}}</cover-view>
      <cover-view class="map-empty-label" wx:if="{{!mapPointCount}}">订单地址暂无坐标，先显示福鼎市地图</cover-view>
    </map>
  </view>

  <view class="vehicle-sheet">
    <view class="sheet-handle"></view>
    <view class="sheet-head">
      <view>
        <view class="sheet-title">选择车型</view>
        <view class="sheet-sub">{{taskName}} · {{routeText}}</view>
      </view>
      <view class="change-tip">像打车一样选</view>
    </view>

    <view class="vehicle-list">
      <block wx:for="{{vehicles}}" wx:key="id">
        <view class="vehicle-row {{selectedVehicle === item.id ? 'active' : ''}}" data-id="{{item.id}}" bindtap="selectVehicle">
          <view class="vehicle-icon {{item.id}}">{{item.icon}}</view>
          <view class="vehicle-main">
            <view class="vehicle-line">
              <text class="vehicle-name">{{item.name}}</text>
              <text class="vehicle-tag">{{item.tag}}</text>
            </view>
            <view class="vehicle-desc">{{item.desc}}</view>
            <view class="vehicle-capacity">{{item.capacity}}</view>
          </view>
          <view class="vehicle-price">
            <view>{{item.priceText}}</view>
            <text wx:if="{{selectedVehicle === item.id}}">已选</text>
          </view>
        </view>
      </block>
    </view>
  </view>

  <view class="bottom-bar">
    <button class="confirm-btn" bindtap="confirm">确认车型</button>
  </view>
</view>
