page {
  color: #172027;
  background: #f4f1e9;
  font-family: "STSong", "Songti SC", serif;
}

button::after { border: 0; }

.page { min-height: 100vh; padding: 28rpx 28rpx 180rpx; box-sizing: border-box; }
.card { margin-bottom: 22rpx; padding: 28rpx; border-radius: 28rpx; background: #fffdf8; box-shadow: 0 14rpx 36rpx rgba(30, 35, 32, 0.08); }
.muted { color: #81857f; font-size: 24rpx; }
.primary { color: #fff; background: #d14f22; font-weight: 800; }
.empty { padding: 100rpx 30rpx; color: #8a8d87; text-align: center; }
