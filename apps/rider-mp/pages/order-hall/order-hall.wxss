.hall-page { padding-top: 0; }
.hero { margin: 0 -28rpx 28rpx; padding: 54rpx 34rpx 38rpx; color: #f7f0df; background: radial-gradient(circle at 84% 10%, #8b5a2b 0, #253229 30%, #111820 72%); }
.eyebrow { color: #d9a45f; font-size: 20rpx; letter-spacing: 4rpx; }
.hero-row { margin-top: 20rpx; display: flex; align-items: flex-end; justify-content: space-between; gap: 20rpx; }
.title { font-size: 54rpx; font-weight: 900; }
.sub { margin-top: 10rpx; color: #b9c0b9; font-size: 23rpx; }
.online-btn { width: 126rpx; height: 68rpx; margin: 0; border-radius: 40rpx; color: #18211d; background: #e7a449; font-size: 27rpx; font-weight: 900; }
.online-btn.on { color: #f5eee0; background: #3a4640; }
.login-title { margin-bottom: 10rpx; font-size: 34rpx; font-weight: 900; }
.login-btn { margin-top: 28rpx; border-radius: 40rpx; }
.status-strip { margin-bottom: 22rpx; padding: 20rpx 24rpx; border: 2rpx solid #ded9cc; border-radius: 22rpx; display: flex; align-items: center; gap: 12rpx; font-size: 25rpx; }
.dot { width: 16rpx; height: 16rpx; border-radius: 50%; background: #a9aca6; }.dot.on { background: #2b9b61; box-shadow: 0 0 0 8rpx rgba(43,155,97,.12); }.vehicle { margin-left: auto; color: #9a5d2c; }
.order-head { display: flex; justify-content: space-between; align-items: center; }.service { font-size: 32rpx; font-weight: 900; }.vehicle-tag { margin-left: 12rpx; padding: 6rpx 12rpx; color: #8b6038; background: #f3e8d8; border-radius: 12rpx; font-size: 20rpx; }.income { color: #cf4b20; font-size: 40rpx; font-weight: 900; }
.route { margin-top: 22rpx; display: flex; align-items: center; gap: 16rpx; font-size: 27rpx; font-weight: 700; }.pickup-dot,.dropoff-dot { width: 18rpx; height: 18rpx; border-radius: 6rpx; background: #d34d25; }.dropoff-dot { background: #268b62; }.route-line { width: 2rpx; height: 24rpx; margin: 6rpx 0 -12rpx 8rpx; background: #d7d2c8; }.meta { margin: 24rpx 0; color: #7c817b; font-size: 23rpx; }.claim-btn { border-radius: 40rpx; color: #fff; background: linear-gradient(100deg,#d86129,#bd321f); font-weight: 900; }
