.profile-hero { display: flex; align-items: center; gap: 24rpx; background: #18211d; color: #fff8e8; }.avatar { width: 92rpx; height: 92rpx; border-radius: 30rpx; display: flex; align-items: center; justify-content: center; background: #d69545; font-size: 40rpx; font-weight: 900; }.name { margin-bottom: 10rpx; font-size: 36rpx; font-weight: 900; }.income-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20rpx; }.metric { text-align: center; }.value { margin-bottom: 8rpx; font-size: 44rpx; font-weight: 900; }.money { color: #cf4b20; }.row { padding: 22rpx 0; border-bottom: 2rpx solid #eee9df; display: flex; justify-content: space-between; }.logout { margin-top: 28rpx; color: #af4228; background: #f7e9df; border-radius: 38rpx; }
.application-title { margin-bottom: 20rpx; font-size: 30rpx; font-weight: 900; }.application input,.picker-row { margin-top: 16rpx; padding: 22rpx; border-radius: 18rpx; background: #f2eee5; }.picker-row,.history-row { display: flex; justify-content: space-between; align-items: center; }.apply-btn { margin-top: 24rpx; border-radius: 38rpx; }.history-row { padding: 20rpx 0; border-bottom: 2rpx solid #eee9df; }
