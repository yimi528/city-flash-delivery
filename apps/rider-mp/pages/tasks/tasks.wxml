<view class="page">
  <view class="section-title">当前任务</view>
  <block wx:for="{{tasks}}" wx:key="id">
    <view class="card task-card">
      <view class="task-title">{{item.serviceName}} · {{item.vehicleName}}</view>
      <view class="address">起：{{item.pickupName}} {{item.pickupDetail}}</view>
      <view class="address" wx:if="{{item.dropoffName}}">到：{{item.dropoffName}} {{item.dropoffDetail}}</view>
      <view class="actions">
        <button data-lat="{{item.pickupLat}}" data-lng="{{item.pickupLng}}" bindtap="navigate">导航</button>
        <button data-phone="{{item.pickupPhone}}" bindtap="callUser">联系用户</button>
      </view>
      <view class="actions">
        <button data-id="{{item.id}}" bindtap="reportException">上报异常</button>
        <button class="primary" data-id="{{item.id}}" data-status="{{item.status}}" data-arrived="{{item.arrivedAt}}" bindtap="advance">{{item.status === 'PICKING_UP' ? (item.arrivedAt ? '开始服务/配送' : '确认到达') : '确认完成'}}</button>
      </view>
    </view>
  </block>
  <view class="empty" wx:if="{{!tasks.length}}">暂无进行中的任务</view>
</view>
